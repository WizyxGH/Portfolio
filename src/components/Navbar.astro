---
import { Image } from 'astro:assets';
import img3ddnnn from '../assets/media/logo.png';
import img9fn2fb from '../assets/media/profilepicturepro.webp';
import imgopv818 from '../assets/media/profilepicturepro.webp';
const navigation = [
  {
    title: "À propos",
    url: "/about/",
    i18n: "nav_about"
  },
  {
    title: "Réalisations",
    url: "/creations/",
    i18n: "nav_creations"
  },
  {
    title: "Services",
    id: "dropdownButton",
    i18n: "nav_services",
    dropdown: [
      {
        title: "UI/UX Design",
        url: "/services/ui-ux/",
        i18n: "nav_services_ui_ux",
        description: "Conception de maquettes de sites internet, landing page, applications mobiles, SaaS",
        desc_i18n: "nav_services_ui_ux_desc",
        icon: "bx bx-layer"
      },
      {
        title: "Audit UX",
        url: "#",
        i18n: "nav_services_audit_ux",
        description: "Analyse et optimisation de vos parcours utilisateurs.",
        desc_i18n: "nav_services_audit_ux_desc",
        icon: "bx bx-search-alt",
        coming_soon: true
      }
    ]
  },
  {
    title: "Contact",
    url: "/contact/",
    i18n: "nav_contact"
  }
];
---
<header class="bg-brand-primary fixed top-0 left-0 w-full z-50 transition-colors duration-200" id="navbar">
    <div class="mx-auto px-6 lg:px-32 py-3 flex justify-between items-center">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 text-lg font-bold text-white">
            <Image loading="lazy" decoding="async" src={img3ddnnn} alt="Logo Wizyx" class="w-6 h-6" />
            Wizyx
        </a>

        <!-- Bouton Menu Burger (visible sur mobile) -->
        <button id="menuButton" class="text-white text-3xl lg:hidden" aria-label="Ouvrir le menu de navigation">
            <i class="bx bx-menu"></i>
        </button>

        <!-- Menu de navigation -->
        <nav id="navMenu" class="hidden absolute top-full left-0 w-full bg-brand-primary shadow-lg lg:shadow-none lg:static lg:flex lg:items-center lg:space-x-4 lg:w-auto transition-all duration-300">
            <ul class="flex flex-col lg:flex-row lg:space-x-4">
                {navigation.map((item) => (
                    item.dropdown ? (
                        <li class="relative lg:group">
                            <button id={item.id} class="inline-flex items-center px-6 py-2 text-white gap-1 w-full text-left lg:w-auto lg:text-center">
                                <span data-i18n={item.i18n}>{item.title}</span>
                                <i id="dropdownChevron" class='bx bx-chevron-down text-lg text-gray-300 ml-auto lg:ml-0'></i>
                            </button>
                            <ul id="dropdownMenu" class="hidden lg:group-hover:flex flex-col bg-white dark:bg-dark-bg text-brand-primary dark:text-brand-secondary lg:absolute lg:top-full lg:left-0 lg:mt-1 lg:shadow-xl lg:rounded-2xl lg:w-80 lg:p-2 border border-gray-150 dark:border-gray-800/80 transition-all duration-200">
                                {item.dropdown.map((subitem) => (
                                    <li>
                                        {subitem.coming_soon ? (
                                            <div class="block lg:px-3 px-6 py-3 opacity-65 cursor-not-allowed select-none lg:rounded-lg">
                                                <div class="flex items-center gap-3">
                                                    <span class="bg-brand-muted/60 dark:bg-brand-dark/60 text-brand-primary dark:text-brand-secondary p-2.5 text-xl rounded-md flex items-center justify-center shrink-0">
                                                        <i class={subitem.icon}></i>
                                                    </span>
                                                    <div class="flex flex-col flex-1">
                                                        <div class="flex items-center justify-between gap-2">
                                                            <span class="font-bold text-sm" data-i18n={subitem.i18n}>{subitem.title}</span>
                                                            <span class="text-[9px] font-bold uppercase tracking-wider px-1.5 py-0.5 rounded bg-brand-primary/10 text-brand-primary dark:bg-brand-secondary/20 dark:text-brand-secondary whitespace-nowrap" data-i18n="nav_coming_soon">Bientôt</span>
                                                        </div>
                                                        <span class="text-xs text-[#3E3E3E] dark:text-gray-300 leading-relaxed mt-0.5" data-i18n={subitem.desc_i18n}>{subitem.description}</span>
                                                    </div>
                                                </div>
                                            </div>
                                        ) : (
                                            <a href={subitem.url} class="group block lg:px-3 px-6 py-3 hover:bg-brand-muted dark:hover:bg-brand-dark hover:text-brand-primary dark:hover:text-brand-secondary hover:font-semibold lg:rounded-lg">
                                                <div class="flex items-center gap-3">
                                                    <span class="bg-brand-muted dark:bg-brand-dark text-brand-primary dark:text-brand-secondary p-2.5 text-xl rounded-md flex items-center justify-center group-hover:bg-brand-primary group-hover:text-white shrink-0 transition-colors duration-200">
                                                        <i class={subitem.icon}></i>
                                                    </span>
                                                    <div class="flex flex-col">
                                                        <span class="font-bold text-sm" data-i18n={subitem.i18n}>{subitem.title}</span>
                                                        <span class="text-xs text-[#3E3E3E] dark:text-gray-300 leading-relaxed mt-0.5" data-i18n={subitem.desc_i18n}>{subitem.description}</span>
                                                    </div>
                                                </div>
                                            </a>
                                        )}
                                    </li>
                                ))}
                            </ul>
                        </li>
                    ) : (
                        <li>
                            <a href={item.url} class="block px-6 py-2 text-white hover:font-semibold" data-i18n={item.i18n}>{item.title}</a>
                        </li>
                    )
                ))}

                <!-- Actions Mobile (Phone + Theme) -->
                <li class="flex lg:hidden items-stretch gap-2 border-t border-white/20 mt-2 px-6 py-3">
                    <a href="tel:+33778407887" class="flex-1 flex items-center gap-3 bg-white/5 border border-white/15 rounded-xl p-3 hover:bg-white/10 transition-colors">
                        <div class="relative shrink-0">
                            <div class="w-10 h-10 rounded-full overflow-hidden border border-white/20 bg-white/10">
                                <Image loading="lazy" decoding="async" src={img9fn2fb} alt="Florian Gertner Kilian" class="w-full h-full object-cover" />
                            </div>
                            <div class="absolute -bottom-0.5 -right-0.5 w-3 h-3 rounded-full bg-emerald-500 border-2 border-brand-primary z-30 animate-pulse"></div>
                        </div>
                        <div class="flex flex-col text-left leading-none justify-center">
                            <span class="text-[9px] text-white/70 font-semibold tracking-wider uppercase">Échangeons de vive voix</span>
                            <span class="text-xs sm:text-sm text-white font-bold mt-1.5 flex items-center gap-1">
                                <i class='bx bxs-phone-call text-emerald-400'></i>
                                07 78 40 78 87
                            </span>
                        </div>
                    </a>
                    
                    <button id="themeToggleMobile" aria-label="Changer de thème" class="shrink-0 flex items-center justify-center bg-white/5 border border-white/15 rounded-xl w-[46px] h-[46px] text-white hover:bg-white/10 transition-colors">
                        <i class="bx bx-sun text-2xl leading-none mt-0.5"></i>
                    </button>

                    <button class="lang-toggle shrink-0 flex items-center justify-center bg-white/5 border border-white/15 rounded-xl px-4 py-3 text-white font-bold text-sm hover:bg-white/10 transition-colors" aria-label="Changer de langue">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 30" class="w-5 h-auto rounded-sm shadow-sm"><clipPath id="s"><path d="M0,0 v30 h60 v-30 z"/></clipPath><clipPath id="t"><path d="M30,15 h30 v15 z v-15 h-30 z h-30 v-15 z v15 h30 z"/></clipPath><g clip-path="url(#s)"><path d="M0,0 v30 h60 v-30 z" fill="#012169"/><path d="M0,0 L60,30 M60,0 L0,30" stroke="#fff" stroke-width="6"/><path d="M0,0 L60,30 M60,0 L0,30" clip-path="url(#t)" stroke="#C8102E" stroke-width="4"/><path d="M30,0 v30 M0,15 h60" stroke="#fff" stroke-width="10"/><path d="M30,0 v30 M0,15 h60" stroke="#C8102E" stroke-width="6"/></g></svg>
                    </button>
                </li>
            </ul>
        </nav>

        <div class="hidden lg:flex items-center gap-2">
            <!-- Phone Card CTA -->
            <a href="tel:+33778407887" class="phone-card bg-white/5 hover:bg-white/10 border border-white/15 hover:border-white/25 rounded-xl px-3.5 py-1.5 flex items-center gap-3 transition-all duration-300 backdrop-blur-md shadow-sm group">
                <div class="relative shrink-0">
                    <div class="w-8 h-8 rounded-full overflow-hidden border border-white/20 bg-white/10">
                        <Image loading="lazy" decoding="async" src={imgopv818} alt="Florian Gertner Kilian" class="w-full h-full object-cover" />
                    </div>
                    <div class="absolute -bottom-0.5 -right-0.5 w-3 h-3 rounded-full bg-emerald-500 border-2 border-brand-primary z-30 animate-pulse"></div>
                </div>
                <div class="flex flex-col text-left leading-none justify-center">
                    <span class="text-[9px] text-white/70 font-semibold tracking-wider uppercase">Échangeons de vive voix</span>
                    <span class="text-xs text-white font-bold mt-1.5 flex items-center gap-1">
                        <i class='bx bxs-phone-call text-emerald-400 group-hover:animate-bounce'></i>
                        07 78 40 78 87
                    </span>
                </div>
            </a>

            <!-- Bouton Theme Toggle - visible uniquement sur desktop -->
            <button id="themeToggleDesktop" aria-label="Basculer le thème" class="hidden lg:flex items-center justify-center text-white hover:bg-white/10 w-9 h-9 rounded-lg transition-colors duration-200">
                <i class='bx bx-sun text-xl leading-none mt-0.5'></i>
            </button>

            <!-- Bouton Langue - visible uniquement sur desktop -->
            <button class="lang-toggle hidden lg:flex items-center justify-center text-white hover:bg-white/10 py-2 px-3 rounded-lg transition-colors duration-200" aria-label="Changer de langue">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 30" class="w-5 h-auto rounded-sm shadow-sm"><clipPath id="s"><path d="M0,0 v30 h60 v-30 z"/></clipPath><clipPath id="t"><path d="M30,15 h30 v15 z v-15 h-30 z h-30 v-15 z v15 h30 z"/></clipPath><g clip-path="url(#s)"><path d="M0,0 v30 h60 v-30 z" fill="#012169"/><path d="M0,0 L60,30 M60,0 L0,30" stroke="#fff" stroke-width="6"/><path d="M0,0 L60,30 M60,0 L0,30" clip-path="url(#t)" stroke="#C8102E" stroke-width="4"/><path d="M30,0 v30 M0,15 h60" stroke="#fff" stroke-width="10"/><path d="M30,0 v30 M0,15 h60" stroke="#C8102E" stroke-width="6"/></g></svg>
            </button>
        </div>
    </div>
</header>

<!-- Spacer -->
<div class="h-[60px] lg:h-[64px]"></div>
