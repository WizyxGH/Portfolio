---
interface Props {
  question: string;
}

const { question } = Astro.props;
---
<details
    class="group bg-brand-surface dark:bg-brand-dark rounded-2xl border border-brand-light/20 dark:border-[#281E5A]/30 p-6 transition-all duration-300 hover:scale-[1.01] hover:shadow-xl hover:border-brand-primary/30 dark:hover:border-brand-secondary/30 animate-on-scroll">
    <summary class="flex items-center justify-between cursor-pointer list-none">
        <span class="text-dark-bg dark:text-white font-medium">{question}</span>
        <i class="bx bx-chevron-down text-2xl text-brand-primary dark:text-brand-secondary transition-transform duration-200 group-open:rotate-180"></i>
    </summary>
    <p class="mt-3 text-sm text-gray-600 dark:text-gray-300 leading-relaxed">
        <slot />
    </p>
</details>
