---
interface Props {
  question: string;
}

const { question } = Astro.props;
---
<details
    class="group bg-white dark:bg-[#0f0f0f] border border-gray-200 dark:border-[#2A2455] rounded-xl p-5 transition-all hover:border-[#411FEB] animate-on-scroll">
    <summary class="flex items-center justify-between cursor-pointer list-none">
        <span class="text-[#121212] dark:text-white font-medium">{question}</span>
        <i class="bx bx-chevron-down text-2xl text-[#411FEB] dark:text-[#5536ED] transition-transform duration-200 group-open:rotate-180"></i>
    </summary>
    <p class="mt-3 text-sm text-gray-600 dark:text-gray-300 leading-relaxed">
        <slot />
    </p>
</details>
