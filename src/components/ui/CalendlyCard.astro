---
import Button from './Button.astro';
---
<div class="w-full lg:col-span-2 bg-[#F0ECFF] dark:bg-brand-secondary/10 border border-brand-light/20 dark:border-[#281E5A]/50 text-brand-primary dark:text-brand-secondary rounded-3xl shadow-md p-6 flex flex-col gap-4">
    <h3 class="text-lg md:text-xl font-bold text-center leading-tight text-dark-bg dark:text-white">Prendre un<br>rendez-vous gratuit
    </h3>
    <div class="rounded-2xl bg-white/70 dark:bg-dark-bg/50 border border-white/80 dark:border-[#281E5A]/30 p-4 shadow-inner">
        <div
            class="grid grid-cols-7 text-[10px] font-semibold text-center uppercase tracking-wide mb-3 text-dark-bg/80 dark:text-gray-400">
            <span>LUN</span><span>MAR</span><span>MER</span><span>JEU</span><span>VEN</span><span>SAM</span><span>DIM</span>
        </div>
        <div class="grid grid-cols-7 gap-2 text-base font-semibold text-center text-dark-bg dark:text-white">
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">1</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">2</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">3</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">4</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">5</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">6</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">7</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">8</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">9</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">10</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">11</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">12</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">13</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">14</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">15</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">16</span>
            <span
                class="w-9 h-9 flex items-center justify-center rounded-full bg-brand-primary text-white shadow-md">17</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">18</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">19</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">20</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">21</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">22</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">23</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">24</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">25</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">26</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">27</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">28</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">29</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">30</span>
            <span class="w-9 h-9 flex items-center justify-center rounded-full bg-white/90 dark:bg-dark-bg/80">31</span>
        </div>
    </div>
    <Button href="https://calendly.com/floriangk/30min" target="_blank" rel="noopener noreferrer" variant="primary" size="md" class="w-full">
        <span>Réserver 30 min</span>
        <i class='bx bx-right-arrow-alt text-2xl'></i>
    </Button>
    <p class="text-xs text-center text-[#2D1D7F] dark:text-[#A090F0] opacity-80">Disponibilités mises à jour en temps réel.
    </p>
</div>
