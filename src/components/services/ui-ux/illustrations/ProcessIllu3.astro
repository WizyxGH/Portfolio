---
import { Image } from 'astro:assets';
import imgd624hhi from '../../../../assets/media/profilepicturepro.webp';
import imgevnu3o from '../../../../assets/media/profilepicturepro.webp';
import imgzx5gtf from '../../../../assets/media/photo/thibautmaensrabier.webp';
export interface Props {
    id?: string;
    class?: string;
}
const { id, class: className = "" } = Astro.props;
---
<div id={id} class={`${className}`}>
                            <div class="relative w-full h-full flex items-center justify-center p-4">
                                <!-- Hi-Fi Dashboard Mockup -->
                                <div class="w-full max-w-[340px] aspect-video bg-white dark:bg-brand-darker rounded-2xl border-2 border-gray-100 dark:border-brand-border-dark shadow-2xl flex overflow-hidden relative transition-colors duration-200">
                                    <!-- Sidebar -->
                                    <div class="w-14 bg-brand-surface dark:bg-dark-bg border-r border-brand-muted dark:border-gray-800 p-3 space-y-4 flex flex-col items-center">
                                        <div class="w-8 h-8 rounded-xl bg-gradient-to-tr from-brand-secondary to-brand-primary flex items-center justify-center text-white font-bold text-sm shadow-md">F</div>
                                        <div class="w-6 h-6 rounded-lg bg-brand-primary/10 dark:bg-white/5 flex items-center justify-center text-brand-primary dark:text-brand-secondary"><i class='bx bxs-dashboard text-sm'></i></div>
                                        <div class="w-6 h-6 rounded flex items-center justify-center text-gray-400 hover:text-brand-primary"><i class='bx bx-analyse text-sm'></i></div>
                                        <div class="w-6 h-6 rounded flex items-center justify-center text-gray-400 hover:text-brand-primary"><i class='bx bx-cog text-sm'></i></div>
                                    </div>
                                    <!-- Main body -->
                                    <div class="flex-1 p-4 flex flex-col justify-between relative">
                                        <!-- Header hi-fi -->
                                        <div class="flex justify-between items-center pb-2 border-b border-gray-100 dark:border-gray-800">
                                            <span class="text-xs font-bold text-dark-bg dark:text-white">Projet PHOQ.tv</span>
                                            <div class="flex items-center gap-2">
                                                <!-- Theme toggler -->
                                                <div class="w-7 h-4 rounded-full bg-gray-250 dark:bg-brand-primary p-0.5 flex items-center dark:justify-end transition-all">
                                                    <div class="w-3 h-3 rounded-full bg-white shadow-md"></div>
                                                </div>
                                                <Image loading="lazy" decoding="async" src={imgzx5gtf} alt="Avatar" class="w-6 h-6 rounded-full object-cover border border-brand-primary" />
                                            </div>
                                        </div>
                                        <!-- Grid cards hi-fi -->
                                        <div class="grid grid-cols-2 gap-3 my-2 flex-1">
                                            <!-- Card 1 -->
                                            <div class="bg-gradient-to-br from-brand-muted/60 to-brand-surface/60 dark:from-brand-secondary/5 dark:to-brand-primary/5 border border-brand-light/30 dark:border-[#281E5A]/50 rounded-xl p-3 flex flex-col justify-between shadow-sm">
                                                <span class="text-[9px] font-semibold text-gray-400">Conversion</span>
                                                <div class="flex items-baseline gap-1">
                                                    <span class="text-base font-extrabold text-brand-primary dark:text-brand-secondary">+35%</span>
                                                    <span class="text-[8px] text-green-500 font-bold"><i class='bx bx-trending-up'></i></span>
                                                </div>
                                                <!-- Mini chart bar visual -->
                                                <div class="flex items-end gap-1 h-5 mt-1">
                                                    <div class="w-2 h-2.5 rounded-t bg-gray-200 dark:bg-gray-800"></div>
                                                    <div class="w-2 h-4 rounded-t bg-gray-300 dark:bg-gray-700"></div>
                                                    <div class="w-2 h-2 rounded-t bg-gray-200 dark:bg-gray-800"></div>
                                                    <div class="w-2 h-5 rounded-t bg-gradient-to-t from-brand-secondary to-brand-primary shadow-md"></div>
                                                </div>
                                            </div>
                                            <!-- Card 2 -->
                                            <div class="bg-white dark:bg-brand-dark border border-brand-light/20 dark:border-[#281E5A]/80 rounded-xl p-3 flex flex-col justify-between shadow-sm">
                                                <span class="text-[9px] font-semibold text-gray-400">Statut</span>
                                                <div class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-green-500/10 text-green-500 text-[8px] font-bold w-max">
                                                    <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> Actif
                                                </div>
                                                <div class="w-full h-2 bg-gray-100 dark:bg-gray-800 rounded-full overflow-hidden mt-2">
                                                    <div class="w-4/5 h-full bg-brand-primary dark:bg-brand-secondary"></div>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <!-- Bottom UI status bar -->
                                        <div class="flex items-center justify-between text-[7px] text-gray-400">
                                            <span>Dernière synchro : Il y a 2m</span>
                                            <span class="text-brand-primary dark:text-brand-secondary font-bold">100% opérationnel</span>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Floating Color Palette Widget -->
                                <div class="absolute -top-1 -right-2 bg-white dark:bg-dark-bg border border-brand-light/40 dark:border-[#281E5A] rounded-xl p-3 shadow-xl space-y-1">
                                    <span class="text-[8px] font-bold text-gray-400 uppercase tracking-wider block">Palette</span>
                                    <div class="flex gap-1.5">
                                        <div class="w-4 h-4 rounded-full bg-brand-primary border border-white/20"></div>
                                        <div class="w-4 h-4 rounded-full bg-brand-secondary border border-white/20"></div>
                                        <div class="w-4 h-4 rounded-full bg-brand-light border border-white/20"></div>
                                    </div>
                                </div>
                                
                                <!-- Floating Typography Widget -->
                                <div class="absolute -bottom-2 -left-2 bg-white dark:bg-dark-bg border border-brand-light/40 dark:border-[#281E5A] rounded-xl p-2.5 shadow-xl flex items-center gap-2">
                                    <span class="text-sm font-extrabold text-brand-primary dark:text-brand-secondary">Aa</span>
                                    <div class="text-left leading-none">
                                        <span class="text-[9px] font-bold text-dark-bg dark:text-white block">Inter</span>
                                        <span class="text-[7px] text-gray-400 font-semibold">Sans-serif</span>
                                    </div>
                                </div>
                            </div>
                        </div>
