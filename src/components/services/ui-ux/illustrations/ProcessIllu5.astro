---
import { Image } from 'astro:assets';
export interface Props {
    id?: string;
    class?: string;
}
const { id, class: className = "" } = Astro.props;
---
<div id={id} class={`${className}`}>
                            <div class="relative w-full h-full flex flex-col sm:flex-row items-center justify-center gap-4 p-4">
                                <!-- Left: Code Editor Mockup -->
                                <div class="w-40 sm:w-44 aspect-square bg-[#1E1E2F] border border-gray-800 rounded-xl shadow-lg p-3 flex flex-col justify-between font-mono text-[7px] text-[#A9B2C3] leading-normal relative overflow-hidden transition-colors duration-200">
                                    <!-- Header bar -->
                                    <div class="flex items-center justify-between pb-1.5 border-b border-gray-800/80 mb-2">
                                        <div class="flex gap-1.5">
                                            <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
                                            <span class="w-1.5 h-1.5 rounded-full bg-yellow-500"></span>
                                            <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
                                        </div>
                                        <span class="text-[5px] text-gray-500 uppercase tracking-widest font-semibold">tailwind.config.js</span>
                                    </div>
                                    <!-- Code lines -->
                                    <div class="flex-1 space-y-1">
                                        <p class="text-blue-400">module<span class="text-white">.</span>exports <span class="text-white">= {"{"}</span></p>
                                        <p class="pl-2 text-purple-400">theme<span class="text-white">: {"{"}</span></p>
                                        <p class="pl-4 text-gray-400">colors<span class="text-white">: {"{"}</span></p>
                                        <p class="pl-6 text-orange-400">primary<span class="text-white">: </span><span class="text-green-400">"var(--color-brand-primary)"</span><span class="text-white">,</span></p>
                                        <p class="pl-6 text-orange-400">secondary<span class="text-white">: </span><span class="text-green-400">"var(--color-brand-secondary)"</span></p>
                                        <p class="pl-4 text-white">{"}"},</p>
                                        <p class="pl-4 text-gray-400">borderRadius<span class="text-white">: {"{"}</span></p>
                                        <p class="pl-6 text-orange-400">xl<span class="text-white">: </span><span class="text-green-400">"12px"</span></p>
                                        <p class="pl-4 text-white">{"}"}</p>
                                        <p class="pl-2 text-white">{"}"}</p>
                                        <p class="text-white">{"}"}</p>
                                    </div>
                                </div>
                                
                                <!-- Right: Figma Inspect Card -->
                                <div class="w-40 sm:w-44 aspect-square bg-white dark:bg-brand-dark border-2 border-dashed border-brand-light dark:border-[#281E5A] rounded-xl shadow-lg p-3 flex flex-col justify-between relative transition-colors duration-200">
                                    <span class="text-[7px] font-bold text-brand-primary dark:text-brand-secondary uppercase tracking-wider block">Figma Dev Mode</span>
                                    
                                    <!-- Button component with Figma measurements -->
                                    <div class="my-auto relative p-4 flex items-center justify-center">
                                        <!-- Outline / specs guides -->
                                        <div class="absolute inset-x-2 inset-y-1 border border-red-500/50 bg-red-500/5 rounded-xl"></div>
                                        <!-- Horizontal padding lines -->
                                        <div class="absolute left-2 top-1/2 -translate-y-1/2 w-4 border-t-2 border-red-500 flex items-center justify-center"><span class="text-[5px] text-red-500 font-bold bg-white dark:bg-brand-dark px-0.5 absolute -top-1.5">16</span></div>
                                        <div class="absolute right-2 top-1/2 -translate-y-1/2 w-4 border-t-2 border-red-500 flex items-center justify-center"><span class="text-[5px] text-red-500 font-bold bg-white dark:bg-brand-dark px-0.5 absolute -top-1.5">16</span></div>
                                        <!-- Vertical padding lines -->
                                        <div class="absolute top-1 left-1/2 -translate-x-1/2 h-3 border-l-2 border-red-500 flex items-center justify-center"><span class="text-[5px] text-red-500 font-bold bg-white dark:bg-brand-dark px-0.5 absolute left-1">12</span></div>
                                        <div class="absolute bottom-1 left-1/2 -translate-x-1/2 h-3 border-l-2 border-red-500 flex items-center justify-center"><span class="text-[5px] text-red-500 font-bold bg-white dark:bg-brand-dark px-0.5 absolute left-1">12</span></div>

                                        <!-- Styled primary button inside -->
                                        <button class="relative z-10 bg-brand-primary text-white text-[7px] font-semibold px-4 py-2 rounded-xl pointer-events-none shadow-sm flex items-center gap-1">
                                            <span>Bouton</span>
                                            <i class='bx bx-check-double'></i>
                                        </button>
                                    </div>
                                    
                                    <!-- Component specs description -->
                                    <div class="flex justify-between items-center text-[6px] text-gray-400 font-mono">
                                        <span>h: 32px</span>
                                        <span>r: 12px (xl)</span>
                                    </div>
                                </div>
                            </div>
                        </div>
</div>
