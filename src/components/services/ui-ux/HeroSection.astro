---
import Button from "../../ui/Button.astro";
import { Image } from "astro:assets";
import profilePicture from "../../../assets/media/profilepicturepro.webp";
---

<!-- 1. HERO SECTION -->
<section
    class="w-full px-8 lg:px-32 py-16 bg-brand-primary text-white transition-colors duration-200"
>
    <div
        class="max-w-6xl mx-auto flex flex-col lg:flex-row items-center gap-12"
    >
        <div class="lg:w-2/3 space-y-6 text-left">
            <div class="flex flex-wrap gap-3 animate-fade-in-up">
                <div
                    class="inline-flex items-center gap-2 rounded-full bg-white/10 border border-white/20 px-4 py-1.5 text-white"
                >
                    <i class="bx bxs-star text-yellow-400"></i>
                    <span class="text-sm font-semibold"
                        >100% de clients satisfaits</span
                    >
                </div>
                <div
                    class="inline-flex items-center gap-2 rounded-full bg-white/10 border border-white/20 px-4 py-1.5 text-white"
                >
                    <i class="bx bx-map-pin text-white/80"></i>
                    <span class="text-sm font-semibold"
                        >Toulon, Nice & Remote</span
                    >
                </div>
            </div>
            <h1
                class="text-4xl lg:text-6xl font-bold leading-tight animate-fade-in-up"
                style="animation-delay: 100ms;"
            >
                Conception d'interfaces qui convertissent vos visiteurs en
                acheteurs.
            </h1>
            <p
                class="text-lg opacity-90 leading-relaxed animate-fade-in-up"
                style="animation-delay: 200ms;"
            >
                Que vous lanciez un nouveau projet ou optimisiez l'existant, je
                traduis vos idées en interfaces fluides, esthétiques et
                intuitives. Vous recevez des maquettes Figma structurées et
                prêtes pour le développement.
            </p>
            <!-- Target platforms -->
            <div
                class="flex flex-wrap gap-3.5 pt-2 text-sm text-white/95 animate-fade-in-up"
                style="animation-delay: 250ms;"
            >
                <span
                    class="inline-flex items-center gap-2 px-3.5 py-1.5 bg-white/10 rounded-full border border-white/10 font-medium"
                    ><i class="bx bx-laptop text-base text-white/90"></i> Sites Web
                    / E-commerce</span
                >
                <span
                    class="inline-flex items-center gap-2 px-3.5 py-1.5 bg-white/10 rounded-full border border-white/10 font-medium"
                    ><i class="bx bx-mobile-alt text-base text-white/90"></i> Applications
                    mobiles (iOS/Android)</span
                >
                <span
                    class="inline-flex items-center gap-2 px-3.5 py-1.5 bg-white/10 rounded-full border border-white/10 font-medium"
                    ><i class="bx bx-layer text-base text-white/90"></i> Plateformes
                    SaaS</span
                >
            </div>
            <div
                class="flex flex-col sm:flex-row gap-4 pt-4 animate-fade-in-up"
                style="animation-delay: 300ms;"
            >
                <Button
                    href="https://calendly.com/floriangk/30min"
                    target="_blank"
                    rel="noopener noreferrer"
                    variant="white"
                    size="md"
                    class="w-full sm:w-auto"
                >
                    Prendre un RDV gratuit
                </Button>
                <Button
                    href="/creations/"
                    variant="glass"
                    size="md"
                    class="w-full sm:w-auto"
                >
                    Découvrir mes réalisations
                    <i class="bx bx-arrow-up-right"></i>
                </Button>
            </div>
        </div>
        <div class="lg:w-1/3 flex justify-center">
            <!-- Photo de profil de Florian avec badges flottants -->
            <div class="relative w-64 h-64 lg:w-80 lg:h-80">
                <!-- Effet de halo / dégradé en arrière-plan -->
                <div
                    class="absolute inset-0 bg-gradient-to-tr from-brand-secondary to-brand-primary rounded-3xl opacity-30 blur-lg animate-pulse-slow"
                >
                </div>

                <!-- Conteneur de la photo -->
                <div
                    class="relative w-full h-full rounded-3xl border border-white/20 overflow-hidden shadow-2xl bg-white/5 backdrop-blur-sm animate-scale-in-elastic"
                    style="animation-delay: 150ms;"
                >
                    <Image
                        fetchpriority="high"
                        loading="eager"
                        src={profilePicture}
                        alt="Florian Gertner Kilian"
                        width={320}
                        height={320}
                        class="w-full h-full object-cover"
                    />
                </div>

                <!-- Badges Flottants -->
                <div
                    class="absolute -top-4 -right-4 bg-white text-brand-primary px-4 py-2 rounded-lg font-bold text-sm shadow-lg dark:bg-brand-dark dark:text-white animate-float-badge z-10"
                >
                    Product Designer ✨
                </div>
                <div
                    class="absolute -bottom-4 -left-4 bg-brand-muted text-brand-primary px-4 py-2 rounded-lg font-bold text-sm shadow-lg dark:bg-brand-dark dark:text-white animate-float-badge-reverse z-10"
                >
                    Figma Expert 📐
                </div>
            </div>
        </div>
    </div>
</section>
