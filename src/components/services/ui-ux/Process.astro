---
import ProcessIllu1 from './illustrations/ProcessIllu1.astro';
import ProcessIllu2 from './illustrations/ProcessIllu2.astro';
import ProcessIllu3 from './illustrations/ProcessIllu3.astro';
import ProcessIllu4 from './illustrations/ProcessIllu4.astro';
import ProcessIllu5 from './illustrations/ProcessIllu5.astro';
import { Image } from 'astro:assets';
import imgevnu3o from '../../../assets/media/profilepicturepro.webp';
import imgzx5gtf from '../../../assets/media/photo/thibautmaensrabier.webp';
import imgd624hhi from '../../../assets/media/profilepicturepro.webp';
import imgpal6qk from '../../../assets/media/photo/thibautmaensrabier.webp';
---
        <!-- 4. LA MÉTHODE (CONCRET ET TRANSPARENT) -->
        <div id="processScrollTrack" class="relative lg:h-[400vh] w-full">
            <section class="w-full px-8 lg:px-32 py-24 lg:py-0 bg-white dark:bg-dark-bg transition-colors duration-200 lg:sticky lg:top-0 lg:h-screen lg:flex lg:flex-col lg:justify-center lg:overflow-hidden" id="processSection">
            <div class="max-w-6xl mx-auto space-y-16">
                <div class="text-center space-y-4">
                    <span class="text-sm font-bold text-brand-primary dark:text-brand-secondary uppercase">Le processus</span>
                    <h2 class="text-3xl lg:text-5xl font-bold text-dark-bg dark:text-white">
                        Comment va se dérouler notre collaboration ?
                    </h2>
                    <p class="text-gray-500 dark:text-gray-400 max-w-xl mx-auto text-sm">
                        Pas de blabla inutile, pas de réunions interminables. Une méthode claire en 5 étapes.
                    </p>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start relative">
                    <!-- Left: Scrollable Steps -->
                    <div id="stepsScrollContainer" class="space-y-4 lg:space-y-0 relative pl-4 lg:pl-6 lg:h-[450px] lg:overflow-hidden w-full">
                        <div id="stepsTranslateWrapper" class="transition-transform duration-500 ease-out flex flex-col">
                        <!-- Step 1 -->
                        <div class="process-step group cursor-pointer hover:border-brand-primary/50 dark:hover:border-brand-secondary/50 py-8 lg:py-10 first:lg:pt-0 last:lg:pb-0 pl-8 relative transition-all duration-300 border-l-2 border-gray-100 dark:border-gray-800" data-step="1">
                            <div class="absolute -left-[13px] top-8 lg:top-16 bg-gray-200 dark:bg-gray-800 text-gray-500 dark:text-gray-400 rounded-full w-6 h-6 flex items-center justify-center font-bold text-xs step-number-badge group-hover:bg-brand-primary/50 group-hover:text-white dark:group-hover:bg-brand-secondary/50 transition-all duration-300">
                                1
                            </div>
                            <h3 class="font-bold text-xl lg:text-2xl text-gray-400 dark:text-gray-600 group-hover:text-dark-bg dark:group-hover:text-white transition-colors duration-300 step-title">1. Appel Découverte (30 min)</h3>
                            <p class="text-gray-400 dark:text-gray-600 group-hover:text-gray-600 dark:group-hover:text-gray-300 mt-2 leading-relaxed text-sm lg:text-base transition-colors duration-300 step-desc">
                                Nous échangeons sur votre vision, vos objectifs commerciaux, vos cibles et vos contraintes
                                techniques. C'est gratuit, sans engagement, et cela nous permet de voir si le "fit" est bon.
                            </p>
                            <!-- Mobile-only illustration -->
                            <div class="block lg:hidden mt-6 w-full aspect-video rounded-2xl bg-brand-surface dark:bg-brand-dark/50 border border-brand-light/20 dark:border-[#281E5A]/50 overflow-hidden relative p-4 flex items-center justify-center">
                                <!-- Illustration 5 -->
                                <ProcessIllu5 class="relative w-full h-full flex items-center justify-center p-4 min-h-[260px]" />
                            </div>
                        </div>

                        <!-- Step 2 -->
                        <div class="process-step group cursor-pointer hover:border-brand-primary/50 dark:hover:border-brand-secondary/50 py-8 lg:py-10 pl-8 relative transition-all duration-300 border-l-2 border-gray-100 dark:border-gray-800" data-step="2">
                            <div class="absolute -left-[13px] top-8 lg:top-16 bg-gray-200 dark:bg-gray-800 text-gray-500 dark:text-gray-400 rounded-full w-6 h-6 flex items-center justify-center font-bold text-xs step-number-badge group-hover:bg-brand-primary/50 group-hover:text-white dark:group-hover:bg-brand-secondary/50 transition-all duration-300">
                                2
                            </div>
                            <h3 class="font-bold text-xl lg:text-2xl text-gray-400 dark:text-gray-600 group-hover:text-dark-bg dark:group-hover:text-white transition-colors duration-300 step-title">2. Cadrage UX & Wireframes (La structure)</h3>
                            <p class="text-gray-400 dark:text-gray-600 group-hover:text-gray-600 dark:group-hover:text-gray-300 mt-2 leading-relaxed text-sm lg:text-base transition-colors duration-300 step-desc">
                                Avant d'ajouter de la couleur, nous validons l'arborescence, les parcours utilisateurs et la
                                logique d'affichage sous forme de schémas simplifiés en noir et blanc (wireframes). C'est
                                ici que se joue la simplicité d'utilisation.
                            </p>
                            <!-- Mobile-only illustration -->
                            <div class="block lg:hidden mt-6 w-full aspect-video rounded-2xl bg-brand-surface dark:bg-brand-dark/50 border border-brand-light/20 dark:border-[#281E5A]/50 overflow-hidden relative p-4 flex items-center justify-center">
                                <!-- Illustration 2: Wireframe Mockup -->
                                <div class="relative w-full h-full flex items-center justify-center p-4 min-h-[260px]">
                                    <!-- Grid Paper style background -->
                                    <div class="absolute inset-0 bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] dark:bg-[radial-gradient(var(--color-brand-border-dark)_1px,transparent_1px)] [background-size:16px_16px] opacity-60"></div>
                                    
                                    <!-- Wireframe Dashboard Mockup -->
                                    <div class="w-full max-w-[280px] sm:max-w-[320px] aspect-video bg-white dark:bg-dark-bg rounded-xl border border-gray-300 dark:border-gray-700 shadow-md flex overflow-hidden relative transition-colors duration-200">
                                        <!-- Sidebar -->
                                        <div class="w-12 border-r border-gray-200 dark:border-gray-800 p-2 space-y-2 flex flex-col items-center">
                                            <div class="w-6 h-6 rounded bg-gray-200 dark:bg-gray-800"></div>
                                            <div class="w-4 h-1.5 rounded bg-gray-100 dark:bg-gray-900"></div>
                                            <div class="w-4 h-1.5 rounded bg-gray-100 dark:bg-gray-900"></div>
                                            <div class="w-4 h-1.5 rounded bg-gray-100 dark:bg-gray-900"></div>
                                        </div>
                                        <!-- Main body -->
                                        <div class="flex-1 p-3 flex flex-col justify-between relative">
                                            <!-- Header wireframe -->
                                            <div class="flex justify-between items-center pb-2 border-b border-gray-100 dark:border-gray-900">
                                                <div class="w-16 h-3 rounded bg-gray-200 dark:bg-gray-800"></div>
                                                <div class="w-6 h-6 rounded-full bg-gray-100 dark:bg-gray-800"></div>
                                            </div>
                                            <!-- Grid cards wireframe -->
                                            <div class="grid grid-cols-2 gap-2 my-2 flex-1">
                                                <div class="border border-dashed border-gray-300 dark:border-gray-700 rounded-lg p-2 flex flex-col justify-between">
                                                    <div class="w-6 h-6 rounded bg-gray-100 dark:bg-gray-800"></div>
                                                    <div class="space-y-1">
                                                        <div class="w-10 h-1.5 rounded bg-gray-200 dark:bg-gray-800"></div>
                                                        <div class="w-6 h-1 rounded bg-gray-100 dark:bg-gray-900"></div>
                                                    </div>
                                                </div>
                                                <div class="border border-dashed border-gray-300 dark:border-gray-755 rounded-lg p-2 flex flex-col justify-between">
                                                    <!-- Image placeholder symbol (cross lines) -->
                                                    <div class="w-full h-8 rounded border border-gray-200 dark:border-gray-800 relative overflow-hidden flex items-center justify-center">
                                                        <div class="absolute w-full h-[1px] bg-gray-200 dark:bg-gray-800 rotate-12"></div>
                                                        <div class="absolute w-full h-[1px] bg-gray-200 dark:bg-gray-800 -rotate-12"></div>
                                                        <i class='bx bx-image text-gray-300 dark:text-gray-700 text-sm'></i>
                                                    </div>
                                                    <div class="w-12 h-1.5 rounded bg-gray-200 dark:bg-gray-800 mt-1"></div>
                                                </div>
                                            </div>
                                            <!-- Bottom status -->
                                            <div class="w-full h-3 rounded bg-gray-100 dark:bg-gray-900"></div>
                                        </div>
                                    </div>
                                    <!-- Flow Arrow Overlay -->
                                    <div class="absolute right-2 top-1/2 -translate-y-1/2 flex flex-col items-center">
                                        <div class="w-6 h-6 rounded-full bg-brand-primary/10 border border-brand-primary dark:border-brand-secondary flex items-center justify-center text-xs text-brand-primary dark:text-brand-secondary font-bold shadow-md">
                                            <i class='bx bx-mouse-pointer'></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Step 3 -->
                        <div class="process-step group cursor-pointer hover:border-brand-primary/50 dark:hover:border-brand-secondary/50 py-8 lg:py-10 pl-8 relative transition-all duration-300 border-l-2 border-gray-100 dark:border-gray-800" data-step="3">
                            <div class="absolute -left-[13px] top-8 lg:top-16 bg-gray-200 dark:bg-gray-800 text-gray-500 dark:text-gray-400 rounded-full w-6 h-6 flex items-center justify-center font-bold text-xs step-number-badge group-hover:bg-brand-primary/50 group-hover:text-white dark:group-hover:bg-brand-secondary/50 transition-all duration-300">
                                3
                            </div>
                            <h3 class="font-bold text-xl lg:text-2xl text-gray-400 dark:text-gray-600 group-hover:text-dark-bg dark:group-hover:text-white transition-colors duration-300 step-title">3. Direction Artistique & UI Premium (Le visuel)</h3>
                            <p class="text-gray-400 dark:text-gray-600 group-hover:text-gray-600 dark:group-hover:text-gray-300 mt-2 leading-relaxed text-sm lg:text-base transition-colors duration-300 step-desc">
                                Création de l'identité visuelle de votre interface. Typographies modernes, palette de
                                couleurs harmonieuse, icônes, contrastes soignés. Nous concevons un design haut de gamme et
                                à votre image.
                            </p>
                            <!-- Mobile-only illustration -->
                            <div class="block lg:hidden mt-6 w-full aspect-video rounded-2xl bg-brand-surface dark:bg-brand-dark/50 border border-brand-light/20 dark:border-[#281E5A]/50 overflow-hidden relative p-4 flex items-center justify-center">
                                <!-- Illustration 3: Hi-Fi Dashboard Mockup -->
                                <div class="relative w-full h-full flex items-center justify-center p-4 min-h-[260px]">
                                    <!-- Hi-Fi Dashboard Mockup -->
                                    <div class="w-full max-w-[280px] sm:max-w-[320px] aspect-video bg-white dark:bg-brand-darker rounded-xl border-2 border-gray-100 dark:border-brand-border-dark shadow-xl flex overflow-hidden relative transition-colors duration-200">
                                        <!-- Sidebar -->
                                        <div class="w-12 bg-brand-surface dark:bg-dark-bg border-r border-brand-muted dark:border-gray-800 p-2 space-y-3 flex flex-col items-center">
                                            <div class="w-6 h-6 rounded-lg bg-gradient-to-tr from-brand-secondary to-brand-primary flex items-center justify-center text-white text-xs font-bold">F</div>
                                            <div class="w-5 h-5 rounded bg-brand-primary/10 dark:bg-white/5 flex items-center justify-center text-brand-primary dark:text-brand-secondary"><i class='bx bxs-dashboard text-xs'></i></div>
                                            <div class="w-5 h-5 rounded flex items-center justify-center text-gray-400 hover:text-brand-primary"><i class='bx bx-analyse text-xs'></i></div>
                                        </div>
                                        <!-- Main body -->
                                        <div class="flex-1 p-3 flex flex-col justify-between relative">
                                            <!-- Header hi-fi -->
                                            <div class="flex justify-between items-center pb-2 border-b border-gray-100 dark:border-gray-800">
                                                <span class="text-[9px] font-bold text-dark-bg dark:text-white">Projet PHOQ</span>
                                                <div class="flex items-center gap-1">
                                                    <!-- Theme toggler -->
                                                    <div class="w-5 h-3 rounded-full bg-gray-200 dark:bg-brand-primary p-0.5 flex items-center dark:justify-end transition-all">
                                                        <div class="w-2.5 h-2.5 rounded-full bg-white shadow-sm"></div>
                                                    </div>
                                                    <Image loading="lazy" decoding="async" src={imgzx5gtf} alt="Avatar" class="w-4 h-4 rounded-full object-cover border border-brand-primary" />
                                                </div>
                                            </div>
                                            <!-- Grid cards hi-fi -->
                                            <div class="grid grid-cols-2 gap-2 my-2 flex-1">
                                                <div class="bg-gradient-to-br from-brand-muted/60 to-brand-surface/60 dark:from-brand-secondary/5 dark:to-brand-primary/5 border border-brand-light/30 dark:border-[#281E5A]/50 rounded-lg p-2 flex flex-col justify-between shadow-sm">
                                                    <span class="text-[7px] font-semibold text-gray-400">Conversion</span>
                                                    <div class="flex items-baseline gap-0.5">
                                                        <span class="text-xs font-extrabold text-brand-primary dark:text-brand-secondary">+35%</span>
                                                        <span class="text-[6px] text-green-500 font-bold"><i class='bx bx-trending-up'></i></span>
                                                    </div>
                                                </div>
                                                <div class="bg-white dark:bg-brand-dark border border-brand-light/20 dark:border-[#281E5A]/80 rounded-lg p-2 flex flex-col justify-between shadow-sm">
                                                    <span class="text-[7px] font-semibold text-gray-400">Statut</span>
                                                    <div class="inline-flex items-center gap-0.5 px-1 py-0.5 rounded-full bg-green-500/10 text-green-500 text-[5px] font-bold w-max">
                                                        Actif
                                                    </div>
                                                </div>
                                            </div>
                                            
                                            <!-- Bottom UI status bar -->
                                            <div class="flex items-center justify-between text-[5px] text-gray-400">
                                                <span>Synchro OK</span>
                                                <span class="text-brand-primary dark:text-brand-secondary font-bold">100% opérationnel</span>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <!-- Floating Color Palette Widget -->
                                    <div class="absolute -top-1 -right-2 bg-white dark:bg-dark-bg border border-brand-light/40 dark:border-[#281E5A] rounded-xl p-2 shadow-xl space-y-1">
                                        <div class="flex gap-1">
                                            <div class="w-3 h-3 rounded-full bg-brand-primary"></div>
                                            <div class="w-3 h-3 rounded-full bg-brand-secondary"></div>
                                            <div class="w-3 h-3 rounded-full bg-brand-light"></div>
                                        </div>
                                    </div>
                                    
                                    <!-- Floating Typography Widget -->
                                    <div class="absolute -bottom-2 -left-2 bg-white dark:bg-dark-bg border border-brand-light/40 dark:border-[#281E5A] rounded-xl p-2 shadow-xl flex items-center gap-1.5">
                                        <span class="text-[10px] font-extrabold text-brand-primary dark:text-brand-secondary">Aa</span>
                                        <span class="text-[7px] font-bold text-dark-bg dark:text-white">Inter</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Step 4 -->
                        <div class="process-step group cursor-pointer hover:border-brand-primary/50 dark:hover:border-brand-secondary/50 py-8 lg:py-10 pl-8 relative transition-all duration-300 border-l-2 border-gray-100 dark:border-gray-800" data-step="4">
                            <div class="absolute -left-[13px] top-8 lg:top-16 bg-gray-200 dark:bg-gray-800 text-gray-500 dark:text-gray-400 rounded-full w-6 h-6 flex items-center justify-center font-bold text-xs step-number-badge group-hover:bg-brand-primary/50 group-hover:text-white dark:group-hover:bg-brand-secondary/50 transition-all duration-300">
                                4
                            </div>
                            <h3 class="font-bold text-xl lg:text-2xl text-gray-400 dark:text-gray-600 group-hover:text-dark-bg dark:group-hover:text-white transition-colors duration-300 step-title">4. Prototype Interactif (Le test)</h3>
                            <p class="text-gray-400 dark:text-gray-600 group-hover:text-gray-600 dark:group-hover:text-gray-300 mt-2 leading-relaxed text-sm lg:text-base transition-colors duration-300 step-desc">
                                Je relie les écrans entre eux sur Figma pour créer une simulation cliquable de votre
                                produit. Vous pouvez tester l'expérience en direct sur votre téléphone ou ordinateur comme
                                s'il était déjà codé.
                            </p>
                            <!-- Mobile-only illustration -->
                            <div class="block lg:hidden mt-6 w-full aspect-video rounded-2xl bg-brand-surface dark:bg-brand-dark/50 border border-brand-light/20 dark:border-[#281E5A]/50 overflow-hidden relative p-4 flex items-center justify-center">
                                <!-- Illustration 4: Phone Prototype Mockup -->
                                <div class="relative w-full h-full flex items-center justify-center p-4 min-h-[260px]">
                                    <!-- Phone Mockup -->
                                    <div class="w-32 h-56 rounded-[28px] border-4 border-gray-800 bg-dark-bg shadow-xl p-1 relative overflow-hidden flex flex-col transition-all duration-300">
                                        <!-- Notch -->
                                        <div class="absolute top-1 right-1/2 translate-x-1/2 w-10 h-2 bg-gray-800 rounded-b-xl z-20"></div>
                                        
                                        <!-- Screen container -->
                                        <div class="flex-1 rounded-[20px] bg-white dark:bg-brand-dark overflow-hidden p-2.5 flex flex-col justify-between relative transition-colors duration-200">
                                            <!-- App Header -->
                                            <div class="flex justify-between items-center mt-1">
                                                <i class='bx bx-chevron-left text-brand-primary dark:text-brand-secondary text-xs'></i>
                                                <span class="text-[8px] font-bold text-dark-bg dark:text-white">Validation</span>
                                                <i class='bx bx-dots-horizontal-rounded text-gray-350 text-xs'></i>
                                            </div>
                                            
                                            <!-- Screen component content -->
                                            <div class="my-auto space-y-2 text-center">
                                                <div class="w-8 h-8 rounded-full bg-green-500/10 text-green-500 flex items-center justify-center text-lg mx-auto shadow-inner border border-green-500/20">
                                                    <i class='bx bx-check-circle animate-pulse'></i>
                                                </div>
                                                <span class="text-[8px] font-bold text-dark-bg dark:text-white block">Activer ?</span>
                                            </div>
                                            
                                            <!-- Action Button -->
                                            <div class="w-full relative mt-auto pb-1">
                                                <button class="w-full bg-brand-primary dark:bg-brand-secondary text-white text-[7px] font-semibold py-1.5 rounded-lg shadow-md cursor-none flex items-center justify-center gap-1 relative overflow-hidden">
                                                    <span>Valider</span>
                                                    <i class='bx bx-right-arrow-alt'></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <!-- Floating Wiring Tag -->
                                    <div class="absolute top-8 right-2 bg-brand-primary text-white rounded px-1.5 py-0.5 text-[6px] font-bold shadow-md animate-pulse">
                                        OnClick -> Next
                                    </div>
                                    
                                    <!-- Vector cursor pointer -->
                                    <div class="absolute bottom-10 right-10 z-30 pointer-events-none text-lg text-gray-900 drop-shadow-md animate-bounce">
                                        <i class='bx bxs-mouse-alt text-dark-bg dark:text-white'></i>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Step 5 -->
                        <div class="process-step group cursor-pointer hover:border-brand-primary/50 dark:hover:border-brand-secondary/50 py-8 lg:py-10 pl-8 relative transition-all duration-300 border-l-2 border-gray-100 dark:border-gray-800" data-step="5">
                            <div class="absolute -left-[13px] top-8 lg:top-16 bg-gray-200 dark:bg-gray-800 text-gray-500 dark:text-gray-400 rounded-full w-6 h-6 flex items-center justify-center font-bold text-xs step-number-badge group-hover:bg-brand-primary/50 group-hover:text-white dark:group-hover:bg-brand-secondary/50 transition-all duration-300">
                                5
                            </div>
                            <h3 class="font-bold text-xl lg:text-2xl text-gray-400 dark:text-gray-600 group-hover:text-dark-bg dark:group-hover:text-white transition-colors duration-300 step-title">5. Handoff Développeur & Design System (La livraison)</h3>
                            <p class="text-gray-400 dark:text-gray-600 group-hover:text-gray-600 dark:group-hover:text-gray-300 mt-2 leading-relaxed text-sm lg:text-base transition-colors duration-300 step-desc">
                                Livraison du fichier de conception Figma parfaitement structuré. Il contient une
                                bibliothèque d'éléments réutilisables (Design System) et les différents comportements des
                                boutons (au survol, cliqués) pour faciliter le travail des développeurs.
                            </p>
                            <!-- Mobile-only illustration -->
                            <div class="block lg:hidden mt-6 w-full aspect-video rounded-2xl bg-brand-surface dark:bg-brand-dark/50 border border-brand-light/20 dark:border-[#281E5A]/50 overflow-hidden relative p-4 flex items-center justify-center">
                                <!-- Illustration 5: Handoff split content -->
                                <div class="relative w-full h-full flex flex-row items-center justify-center gap-3 p-2 min-h-[260px]">
                                    <!-- Code Card -->
                                    <div class="w-1/2 aspect-square bg-[#1E1E2F] border border-gray-800 rounded-lg shadow-md p-2 flex flex-col justify-between font-mono text-[5px] text-[#A9B2C3] relative overflow-hidden">
                                        <div class="flex items-center justify-between pb-1 border-b border-gray-800 mb-1">
                                            <span class="text-[4px] text-gray-500">tailwind.config.js</span>
                                        </div>
                                        <div class="flex-1 space-y-0.5">
                                            <p class="text-blue-400">module.exports = {"{"}</p>
                                            <p class="pl-1 text-purple-400">theme: {"{"}</p>
                                            <p class="pl-2 text-orange-400">primary: "var(--color-brand-primary)"</p>
                                            <p class="pl-1 text-white">{"}"}</p>
                                            <p class="text-white">{"}"}</p>
                                        </div>
                                    </div>
                                    
                                    <!-- Design Card -->
                                    <div class="w-1/2 aspect-square bg-white dark:bg-brand-dark border-2 border-dashed border-brand-light dark:border-[#281E5A] rounded-lg shadow-md p-2 flex flex-col justify-between relative">
                                        <span class="text-[6px] font-bold text-brand-primary dark:text-brand-secondary uppercase tracking-wider block">Specs</span>
                                        <div class="my-auto relative p-2 flex items-center justify-center">
                                            <div class="absolute inset-0 border border-red-500/40 bg-red-500/5 rounded-lg"></div>
                                            <button class="relative z-10 bg-brand-primary text-white text-[6px] px-2 py-1 rounded-lg pointer-events-none scale-75">
                                                Bouton
                                            </button>
                                        </div>
                                        <div class="flex justify-between items-center text-[5px] text-gray-400">
                                            <span>h: 32px</span>
                                            <span>r: 12px</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        </div> <!-- End of stepsTranslateWrapper -->
                    </div> <!-- End of stepsScrollContainer -->

                    <!-- Right: Sticky Illustrations Container (Large Screens Only) -->
                    <div class="hidden lg:block lg:sticky lg:top-32 w-full h-[480px] rounded-3xl bg-brand-surface dark:bg-brand-dark/30 border border-brand-light/20 dark:border-[#281E5A]/50 overflow-hidden shadow-inner relative transition-colors duration-200">
                        
                        <!-- Illustration 1: Video Call & Calendar -->
                        <!-- Illustration 1 -->
                        <ProcessIllu1 id="illustration-1" class="absolute inset-0 transition-all duration-500 flex items-center justify-center p-8 opacity-0 scale-95 pointer-events-none" />

                        <!-- Illustration 2: Wireframe Mockup -->
                        <!-- Illustration 2 -->
                        <ProcessIllu2 id="illustration-2" class="absolute inset-0 transition-all duration-500 flex items-center justify-center p-8 opacity-0 scale-95 pointer-events-none" />

                        <!-- Illustration 3: Direction Artistique & UI Premium -->
                        <!-- Illustration 3 -->
                        <ProcessIllu3 id="illustration-3" class="absolute inset-0 transition-all duration-500 flex items-center justify-center p-8 opacity-0 scale-95 pointer-events-none" />

                        <!-- Illustration 4: Phone Prototype Mockup -->
                        <!-- Illustration 4 -->
                        <ProcessIllu4 id="illustration-4" class="absolute inset-0 transition-all duration-500 flex items-center justify-center p-8 opacity-0 scale-95 pointer-events-none" />

                        <!-- Illustration 5: Handoff & Design System -->
                        <!-- Illustration 5 -->
                        <ProcessIllu5 id="illustration-5" class="absolute inset-0 transition-all duration-500 flex items-center justify-center p-8 opacity-0 scale-95 pointer-events-none" />

                    </div>
                </div>
            </div>
        </section>
