---
import Layout from '../layouts/Layout.astro';
---
<Layout title="legal" description="" body_class="">
<main class="flex-1 pt-8 pb-12 lg:px-32 px-8">
        <div class="max-w-4xl mx-auto space-y-10">
            <header class="space-y-4">
                <div>
                    <a href="/" class="text-white hover:font-semibold transition-all duration-200">
                        <i class='bx bx-arrow-left-stroke'></i>
                        <span>Retour à l'accueil</span>
                    </a>
                </div>
                <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-brand-secondary">Mentions légales</h1>
            </header>

            <div class="space-y-8 text-left text-gray-800">
                <article class="space-y-3">
                    <h2 class="text-xl font-semibold text-gray-900 dark:text-brand-secondary">1. &Eacute;diteur du site</h2>
                    <div class="rounded-2xl bg-gray-50 border border-gray-100 p-6 space-y-2 shadow-sm">
                        <p><strong>Site :</strong> wizyx.me</p>
                        <p><strong>&Eacute;diteur :</strong> Florian Gertner Kilian</p>
                        <p><strong>Nationalité :</strong> Française</p>
                        <p><strong>Numéro SIRET :</strong> 99994280800018</p>
                        <p><strong>Numéro TVA intracommunautaire :</strong> Coming soon</p>
