                            garantir l'absence d'erreur. L'utilisation du site se fait sous la seule
                            responsabilit&eacute; de l'utilisateur.</p>
                    </div>
                </article>
            </div>
            <div class="mt-12 pt-8 border-t border-gray-200">
                <i class='bx bx-clock'></i>
                <p class="text-sm text-gray-500">Dernière mise à jour : janvier 2026</p>
            </div>
        </div>
    </main>

    

    <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "BreadcrumbList",
            "itemListElement": [
                {
                    "@type": "ListItem",
                    "position": 1,
                    "name": "Accueil",
                    "item": "https://wizyx.me/"
                },
                {
                    "@type": "ListItem",
                    "position": 2,
                    "name": "Mentions légales",
                    "item": "https://wizyx.me/legal/"
                }
            ]
        }
    </script>

</Layout>