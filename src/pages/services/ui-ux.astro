---
import { Image } from 'astro:assets';
import img85xx2l from '../../assets/media/profilepicturepro.webp';
import imgex5s6f from '../../assets/media/profilepicturepro.webp';
import imgyrj1hp from '../../assets/media/photo/thibautmaensrabier.webp';
import imgjc8te from '../../assets/media/profilepicturepro.webp';
import imgbgf5vb from '../../assets/media/photo/thibautmaensrabier.webp';
import img99s2l9 from '../../assets/media/brands/Kosmos Digital.png';
import imgbl3p7 from '../../assets/media/brands/Game4Creator.png';
import img9qe3os from '../../assets/media/photo/thibautmaensrabier.webp';
import imggk5zote from '../../assets/media/photo/lucaskacem.webp';
import imgi9go3 from '../../assets/media/photo/carolineaubert.webp';
import imga79ff from '../../assets/media/photo/jonathanvaissiere.webp';
import imgq6ps7 from '../../assets/media/photo/maximeclick.webp';
import imgPhoq from '../../assets/media/brands/PHOQTV.svg';
import imgDigital from '../../assets/media/brands/Digital Unicorn.svg';
import imgMafigue from '../../assets/media/brands/Mafigue.svg';
import imgJobbrr from '../../assets/media/brands/JOBBRR.svg';
import FaqItem from '../../components/ui/FaqItem.astro';
import CheckListItem from '../../components/ui/CheckListItem.astro';
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Freelance UI/UX Designer - Refonte, Audit & Design d'interfaces - Florian Gertner Kilian" description="Besoin d'une refonte, d'un audit UX/UI ou de concevoir votre site/application ? Je crée des interfaces" body_class="">
<main class="flex-1 flex flex-col">

        <!-- 1. HERO SECTION -->
        <section class="w-full px-8 lg:px-32 py-16 bg-brand-primary text-white transition-colors duration-200">
            <div class="max-w-6xl mx-auto flex flex-col lg:flex-row items-center gap-12">
                <div class="lg:w-2/3 space-y-6 text-left">
                    <div class="flex flex-wrap gap-3 animate-fade-in-up">
                        <div
                            class="inline-flex items-center gap-2 rounded-full bg-white/10 border border-white/20 px-4 py-1.5 text-white">
                            <i class='bx bxs-star text-yellow-400'></i>
                            <span class="text-sm font-semibold">100% de clients satisfaits</span>
                        </div>
                        <div
                            class="inline-flex items-center gap-2 rounded-full bg-white/10 border border-white/20 px-4 py-1.5 text-white">
                            <i class='bx bx-map-pin text-white/80'></i>
                            <span class="text-sm font-semibold">Toulon, Nice & Remote</span>
                        </div>
                    </div>
                    <h1 class="text-4xl lg:text-6xl font-bold leading-tight animate-fade-in-up" style="animation-delay: 100ms;">
                        Conception d'interfaces qui convertissent vos visiteurs en acheteurs.
                    </h1>
                    <p class="text-lg opacity-90 leading-relaxed animate-fade-in-up" style="animation-delay: 200ms;">
                        Que vous lanciez un nouveau projet ou optimisiez l'existant, je traduis vos idées en interfaces fluides, esthétiques et intuitives. Vous recevez des maquettes Figma structurées et prêtes pour le développement.
                    </p>
                    <!-- Target platforms -->
                    <div class="flex flex-wrap gap-3.5 pt-2 text-sm text-white/95 animate-fade-in-up" style="animation-delay: 250ms;">
                        <span class="inline-flex items-center gap-2 px-3.5 py-1.5 bg-white/10 rounded-full border border-white/10 font-medium"><i class='bx bx-laptop text-base text-white/90'></i> Sites Web / E-commerce</span>
                        <span class="inline-flex items-center gap-2 px-3.5 py-1.5 bg-white/10 rounded-full border border-white/10 font-medium"><i class='bx bx-mobile-alt text-base text-white/90'></i> Applications mobiles (iOS/Android)</span>
                        <span class="inline-flex items-center gap-2 px-3.5 py-1.5 bg-white/10 rounded-full border border-white/10 font-medium"><i class='bx bx-layer text-base text-white/90'></i> Plateformes SaaS</span>
                    </div>
                    <div class="flex flex-col sm:flex-row gap-4 pt-4 animate-fade-in-up" style="animation-delay: 300ms;">
                        <a href="https://calendly.com/floriangk/30min" target="_blank" rel="noopener noreferrer"
                            class="w-full sm:w-auto bg-white text-brand-primary px-8 py-4 font-semibold rounded-xl text-center transition-all hover:bg-gray-100 hover:scale-[1.02]">
                            Prendre un RDV gratuit
                        </a>
                        <a href="/creations/"
                            class="w-full sm:w-auto bg-white/10 text-white border border-white/20 px-8 py-4 font-semibold rounded-xl flex items-center justify-center gap-2 transition-all hover:bg-white/20">
                            Découvrir mes réalisations
                            <i class='bx bx-arrow-up-right'></i>
                        </a>
                    </div>
                </div>
                <div class="lg:w-1/3 flex justify-center">
                    <!-- Photo de profil de Florian avec badges flottants -->
                    <div class="relative w-64 h-64 lg:w-80 lg:h-80">
                        <!-- Effet de halo / dégradé en arrière-plan -->
                        <div
                            class="absolute inset-0 bg-gradient-to-tr from-brand-secondary to-brand-primary rounded-3xl opacity-30 blur-lg animate-pulse-slow">
                        </div>

                        <!-- Conteneur de la photo -->
                        <div
                            class="relative w-full h-full rounded-3xl border border-white/20 overflow-hidden shadow-2xl bg-white/5 backdrop-blur-sm animate-scale-in-elastic" style="animation-delay: 150ms;">
                            <Image loading="lazy" decoding="async" src={img85xx2l} alt="Florian Gertner Kilian"
                                class="w-full h-full object-cover" />
                        </div>

                        <!-- Badges Flottants -->
                        <div
                            class="absolute -top-4 -right-4 bg-white text-brand-primary px-4 py-2 rounded-lg font-bold text-sm shadow-lg animate-float-badge z-10">
                            Product Designer ✨
                        </div>
                        <div
                            class="absolute -bottom-4 -left-4 bg-brand-muted text-brand-primary px-4 py-2 rounded-lg font-bold text-sm shadow-lg dark:bg-brand-dark dark:text-white animate-float-badge-reverse z-10">
                            Figma Expert 📐
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- 2. LE PROBLÈME (AGITATION) -->
        <section class="w-full px-8 lg:px-32 py-16 bg-white dark:bg-dark-bg">
            <div class="max-w-5xl mx-auto text-center space-y-12">
                <div class="space-y-4">
                    <h2 class="text-3xl lg:text-4xl font-bold text-dark-bg dark:text-white">
                        Pourquoi un design "moyen" vous coûte plus cher qu'un designer senior
                    </h2>
                    <p class="text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
                        La plupart des produits numériques échouent non pas à cause de leur code, mais à cause d'une
                        expérience utilisateur approximative qui fait fuir les clients et frustre les équipes.
                    </p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-left">
                    <!-- Point 1: Double travail -->
                    <div
                        class="bg-brand-surface dark:bg-brand-dark p-6 rounded-2xl border border-brand-light/20 dark:border-[#281E5A]/30 space-y-3 animate-on-scroll transition-all duration-300 hover:scale-[1.02] hover:shadow-lg hover:border-brand-primary/30 dark:hover:border-brand-secondary/30">
                        <div class="text-red-500 text-3xl"><i class='bx bx-code-block'></i></div>
                        <h3 class="font-bold text-dark-bg dark:text-white">Le piège du double travail (Refonte + Code)
                        </h3>
                        <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">
                            Engager un designer junior sans bagage technique mène souvent à des maquettes irréalistes.
                            Vos développeurs devront bricoler, multiplier les allers-retours ou tout jeter. Corriger une
                            erreur après développement coûte <strong>jusqu'à 100 fois plus cher</strong> qu'en phase de
                            design.
                        </p>
                    </div>

                    <!-- Point 2: Budget marketing gâché -->
                    <div class="bg-brand-surface dark:bg-brand-dark p-6 rounded-2xl border border-brand-light/20 dark:border-[#281E5A]/30 space-y-3 animate-on-scroll transition-all duration-300 hover:scale-[1.02] hover:shadow-lg hover:border-brand-primary/30 dark:hover:border-brand-secondary/30"
                        style="transition-delay: 100ms;">
                        <div class="text-red-500 text-3xl"><i class='bx bx-trending-down'></i></div>
                        <h3 class="font-bold text-dark-bg dark:text-white">Le gaspillage budgétaire (CAC & Publicités)
                        </h3>
                        <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">
                            Attirer du trafic via Google Ads, Meta Ads ou SEO coûte cher. Si l'ergonomie de votre
                            interface est confuse, vos visiteurs s'en vont immédiatement chez vos concurrents. Un design
                            clair et fluide augmente les taux de conversion de <strong>200% à 400%</strong>,
                            rentabilisant chaque euro dépensé en marketing.
                        </p>
                    </div>

                    <!-- Point 3: Support client débordé -->
                    <div class="bg-brand-surface dark:bg-brand-dark p-6 rounded-2xl border border-brand-light/20 dark:border-[#281E5A]/30 space-y-3 animate-on-scroll transition-all duration-300 hover:scale-[1.02] hover:shadow-lg hover:border-brand-primary/30 dark:hover:border-brand-secondary/30"
                        style="transition-delay: 200ms;">
                        <div class="text-red-500 text-3xl"><i class='bx bx-message-rounded-error'></i></div>
                        <h3 class="font-bold text-dark-bg dark:text-white">La surcharge constante du Support Client
                        </h3>
                        <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">
                            Chaque zone d'ombre dans votre parcours utilisateur crée de la frustration et pousse vos
                            clients à contacter le support (tickets d'aide, réclamations). Une UX intuitive résout ces
                            frictions de manière autonome et <strong>réduit drastiquement vos coûts
                                opérationnels</strong> de gestion.
                        </p>
                    </div>

                    <!-- Point 4: Dévalorisation de votre marque -->
                    <div class="bg-brand-surface dark:bg-brand-dark p-6 rounded-2xl border border-brand-light/20 dark:border-[#281E5A]/30 space-y-3 animate-on-scroll transition-all duration-300 hover:scale-[1.02] hover:shadow-lg hover:border-brand-primary/30 dark:hover:border-brand-secondary/30"
                        style="transition-delay: 300ms;">
                        <div class="text-red-500 text-3xl"><i class='bx bx-shield-x'></i></div>
                        <h3 class="font-bold text-dark-bg dark:text-white">La perte de crédibilité et de valeur</h3>
                        <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">
                            Vos clients potentiels n'accorderont jamais leur confiance (ni leur carte bancaire) à une
                            interface obsolète ou instable. Un design premium de niveau mondial rassure instantanément
                            sur votre professionnalisme et vous permet de <strong>justifier des tarifs plus
                                élevés</strong>.
                        </p>
                    </div>
                </div>

                <!-- Données chiffrées & Sources -->
                <div class="bg-brand-muted dark:bg-brand-dark/40 border border-brand-light/60 dark:border-[#281E5A]/60 rounded-2xl p-6 lg:p-8 text-left space-y-6 animate-on-scroll"
                    style="transition-delay: 400ms;">
                    <h4 class="font-bold text-dark-bg dark:text-white text-lg flex items-center gap-2">
                        <i class='bx bx-line-chart text-brand-primary dark:text-brand-secondary text-xl'></i>
                        L'impact financier du design
                    </h4>
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                        <div class="space-y-1">
                            <span class="text-3xl font-extrabold text-brand-primary dark:text-brand-secondary block">+200% à
                                +400%</span>
                            <p class="text-xs text-gray-600 dark:text-gray-400 leading-normal">
                                d'augmentation des taux de conversion grâce à une interface de qualité.
                                <span class="block mt-1 font-semibold text-gray-400 text-[10px]">Source : Forrester
                                    Research</span>
                            </p>
                        </div>
                        <div class="space-y-1">
                            <span class="text-3xl font-extrabold text-brand-primary dark:text-brand-secondary block">100 $ de
                                retour</span>
                            <p class="text-xs text-gray-600 dark:text-gray-400 leading-normal">
                                pour chaque dollar (1 $) investi dans l'amélioration de l'UX (ROI de 9&nbsp;900&nbsp;%).
                                <span class="block mt-1 font-semibold text-gray-400 text-[10px]">Source : Forrester
                                    Research</span>
                            </p>
                        </div>
                        <div class="space-y-1">
                            <span class="text-3xl font-extrabold text-brand-primary dark:text-brand-secondary block">100x moins
                                cher</span>
                            <p class="text-xs text-gray-600 dark:text-gray-400 leading-normal">
                                de corriger un problème ergonomique en phase de design plutôt qu'après codage.
                                <span class="block mt-1 font-semibold text-gray-400 text-[10px]">Source : IBM Systems
                                    Journal</span>
                            </p>
                        </div>
                        <div class="space-y-1">
                            <span class="text-3xl font-extrabold text-brand-primary dark:text-brand-secondary block">+32% de
                                croissance</span>
                            <p class="text-xs text-gray-600 dark:text-gray-400 leading-normal">
                                de chiffre d'affaires sur 5 ans constatée chez les leaders du design.
                                <span class="block mt-1 font-semibold text-gray-400 text-[10px]">Source : McKinsey (The
                                    Business Value of Design)</span>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- 3. LES POINTS FORTS / OBJECTIONS (DEVELOPPEURS & COPYWRITING) -->
        <section class="w-full px-8 lg:px-32 py-16 bg-brand-muted dark:bg-brand-dark">
            <div class="max-w-5xl mx-auto space-y-12">
                <div class="text-center space-y-4">
                    <span class="text-sm font-bold text-brand-primary dark:text-brand-secondary uppercase">Mes points forts</span>
                    <h2 class="text-3xl lg:text-4xl font-bold text-dark-bg dark:text-white">Pourquoi moi plutôt qu'un autre ?</h2>
                    <p class="text-gray-600 dark:text-gray-400 max-w-xl mx-auto text-sm">
                        Une double compétence technique et stratégique pour des interfaces esthétiques, performantes et prêtes à être intégrées.
                    </p>
                </div>
                <div class="flex flex-col lg:flex-row gap-6 lg:gap-12 items-stretch">
                    <!-- Atout Dev -->
                    <div
                        class="lg:w-1/2 bg-white dark:bg-dark-bg p-6 md:p-8 rounded-2xl border-2 border-brand-light dark:border-[#281E5A] flex flex-col justify-between space-y-6 animate-on-scroll transition-all duration-300 hover:scale-[1.01] hover:shadow-xl hover:border-brand-primary dark:hover:border-brand-secondary">
                        <div class="space-y-4">
                            <div
                                class="w-12 h-12 rounded-full bg-brand-primary/15 text-brand-primary dark:bg-brand-secondary/20 dark:text-brand-secondary flex items-center justify-center text-2xl font-semibold">
                                <i class='bx bx-code-alt'></i>
                            </div>
                            <h3 class="text-2xl font-bold text-dark-bg dark:text-white">Je ne dessine pas seulement des maquettes. Je conçois des produits prêts à être codés.</h3>
                            <p class="text-gray-600 dark:text-gray-400 leading-relaxed text-sm">
                                La plupart des designers créent des interfaces superbes qui s'avèrent impossibles à intégrer. Ayant débuté mes études en **BTS SIO** (développement informatique) avant de me spécialiser en design en **BUT MMI**, je sais coder et je comprends vos développeurs.
                            </p>
                            <ul class="space-y-3.5 text-sm text-gray-500 dark:text-gray-400">
                                <li class="flex items-start gap-3"><i
                                        class='bx bx-check text-green-500 text-xl shrink-0 mt-0.5'></i>
                                    <span><strong>Zéro friction de handoff</strong> : Mes fichiers Figma sont construits comme du code (Auto-layout strict, variables, tokens CSS). Vos intégrateurs n'ont qu'à copier-coller les styles.</span>
                                </li>
                                <li class="flex items-start gap-3"><i
                                        class='bx bx-check text-green-500 text-xl shrink-0 mt-0.5'></i>
                                    <span><strong>Design System réutilisable</strong> : Je livre des composants propres et modulables, ce qui permet à vos équipes de faire évoluer le produit à l'infini sans recréer de dette technique.</span>
                                </li>
                                <li class="flex items-start gap-3"><i
                                        class='bx bx-check text-green-500 text-xl shrink-0 mt-0.5'></i>
                                    <span><strong>Faisabilité garantie à 100%</strong> : Pas de propositions irréalistes. Les contraintes de mise en page responsive et de structure sont anticipées dès le premier schéma.</span>
                                </li>
                            </ul>
                        </div>
                        <p class="text-xs font-bold text-brand-primary dark:text-brand-secondary uppercase tracking-wider pt-2 border-t border-gray-100 dark:border-gray-800/80">Vos développeurs vont adorer travailler avec moi, et vous gagnerez un temps précieux.</p>
                    </div>

                    <!-- Atout Copywriting -->
                    <div class="lg:w-1/2 bg-white dark:bg-dark-bg p-6 md:p-8 rounded-2xl border-2 border-brand-light dark:border-[#281E5A] flex flex-col justify-between space-y-6 animate-on-scroll transition-all duration-300 hover:scale-[1.01] hover:shadow-xl hover:border-brand-primary dark:hover:border-brand-secondary"
                        style="transition-delay: 150ms;">
                        <div class="space-y-4">
                            <div
                                class="w-12 h-12 rounded-full bg-brand-primary/15 text-brand-primary dark:bg-brand-secondary/20 dark:text-brand-secondary flex items-center justify-center text-2xl font-semibold">
                                <i class='bx bx-edit'></i>
                            </div>
                            <h3 class="text-2xl font-bold text-dark-bg dark:text-white">Le Design n'est rien sans les mots : je structure votre message pour convaincre.</h3>
                            <p class="text-gray-600 dark:text-gray-400 leading-relaxed text-sm">
                                Une magnifique interface remplie de "Lorem Ipsum" ou de textes fades ne convertira jamais. C'est pourquoi j'intègre le **Copywriting** (persuasion) et l'**UX Writing** (clarté) directement dans mon processus créatif.
                            </p>
                            <ul class="space-y-3.5 text-sm text-gray-500 dark:text-gray-400">
                                <li class="flex items-start gap-3"><i
                                        class='bx bx-check text-green-500 text-xl shrink-0 mt-0.5'></i>
                                    <span><strong>Copywriting de conversion</strong> : Co-rédaction d'accroches percutantes et structuration logique de vos arguments pour lever les objections de vos visiteurs.</span>
                                </li>
                                <li class="flex items-start gap-3"><i
                                        class='bx bx-check text-green-500 text-xl shrink-0 mt-0.5'></i>
                                    <span><strong>UX Writing intuitif</strong> : Soin extrême apporté aux micro-copies (boutons, formulaires, aides) pour guider l'utilisateur de manière invisible et naturelle.</span>
                                </li>
                                <li class="flex items-start gap-3"><i
                                        class='bx bx-check text-green-500 text-xl shrink-0 mt-0.5'></i>
                                    <span><strong>Storytelling de marque</strong> : Conception du parcours de la page comme un entonnoir narratif, amenant le visiteur à s'intéresser, puis à passer à l'action.</span>
                                </li>
                            </ul>
                        </div>
                        <p class="text-xs font-bold text-brand-primary dark:text-brand-secondary uppercase tracking-wider pt-2 border-t border-gray-100 dark:border-gray-800/80">Vous n'avez pas encore rédigé vos textes ? Aucun problème, nous les créons ensemble.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- 4. LA MÉTHODE (CONCRET ET TRANSPARENT) -->
        <div id="processScrollTrack" class="relative lg:h-[400vh] w-full">
            <section class="w-full px-8 lg:px-32 py-24 lg:py-0 bg-white dark:bg-dark-bg transition-colors duration-200 lg:sticky lg:top-0 lg:h-screen lg:flex lg:flex-col lg:justify-center lg:overflow-hidden" id="processSection">
            <div class="max-w-6xl mx-auto space-y-16">
                <div class="text-center space-y-4">
                    <span class="text-sm font-bold text-brand-primary dark:text-brand-secondary uppercase">Le processus</span>
                    <h2 class="text-3xl lg:text-5xl font-bold text-dark-bg dark:text-white">
                        Comment va se dérouler notre collaboration ?
                    </h2>
                    <p class="text-gray-500 dark:text-gray-400 max-w-xl mx-auto text-sm">
                        Pas de blabla inutile, pas de réunions interminables. Une méthode claire en 5 étapes.
                    </p>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start relative">
                    <!-- Left: Scrollable Steps -->
                    <div id="stepsScrollContainer" class="space-y-4 lg:space-y-0 relative pl-4 lg:pl-6 lg:h-[450px] lg:overflow-hidden w-full">
                        <div id="stepsTranslateWrapper" class="transition-transform duration-500 ease-out flex flex-col">
                        <!-- Step 1 -->
                        <div class="process-step group cursor-pointer hover:border-brand-primary/50 dark:hover:border-brand-secondary/50 py-8 lg:py-10 first:lg:pt-0 last:lg:pb-0 pl-8 relative transition-all duration-300 border-l-2 border-gray-100 dark:border-gray-800" data-step="1">
                            <div class="absolute -left-[13px] top-8 lg:top-16 bg-gray-200 dark:bg-gray-800 text-gray-500 dark:text-gray-400 rounded-full w-6 h-6 flex items-center justify-center font-bold text-xs step-number-badge group-hover:bg-brand-primary/50 group-hover:text-white dark:group-hover:bg-brand-secondary/50 transition-all duration-300">
                                1
                            </div>
                            <h3 class="font-bold text-xl lg:text-2xl text-gray-400 dark:text-gray-600 group-hover:text-dark-bg dark:group-hover:text-white transition-colors duration-300 step-title">1. Appel Découverte (30 min)</h3>
                            <p class="text-gray-400 dark:text-gray-600 group-hover:text-gray-600 dark:group-hover:text-gray-300 mt-2 leading-relaxed text-sm lg:text-base transition-colors duration-300 step-desc">
                                Nous échangeons sur votre vision, vos objectifs commerciaux, vos cibles et vos contraintes
                                techniques. C'est gratuit, sans engagement, et cela nous permet de voir si le "fit" est bon.
                            </p>
                            <!-- Mobile-only illustration -->
                            <div class="block lg:hidden mt-6 w-full aspect-video rounded-2xl bg-brand-surface dark:bg-brand-dark/50 border border-brand-light/20 dark:border-[#281E5A]/50 overflow-hidden relative p-4 flex items-center justify-center">
                                <!-- Illustration 1: Video Call & Calendar -->
                                <div class="relative w-full h-full flex items-center justify-center p-4 min-h-[260px]">
                                    <!-- Video call screen mockup -->
                                    <div class="w-full max-w-[280px] sm:max-w-[320px] aspect-video bg-white dark:bg-brand-darker rounded-2xl border-2 border-gray-100 dark:border-brand-border-dark shadow-lg overflow-hidden relative flex flex-col justify-between p-3 transition-colors duration-200">
                                        <!-- Video content (Florian profile) -->
                                        <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-tr from-brand-secondary/20 to-brand-primary/20 dark:from-brand-secondary/10 dark:to-brand-primary/10">
                                            <div class="relative w-16 h-16 sm:w-20 sm:h-20 rounded-full border-2 border-brand-primary overflow-hidden shadow-md">
                                                <Image loading="lazy" decoding="async" src={imgex5s6f} alt="Florian" class="w-full h-full object-cover animate-on-scroll" />
                                            </div>
                                            <!-- Online indicator -->
                                            <div class="absolute bottom-6 right-1/2 translate-x-10 sm:translate-x-12 bg-green-500 border-2 border-white dark:border-brand-darker rounded-full px-2 py-0.5 text-[8px] font-bold text-white uppercase tracking-wider">
                                                Live
                                            </div>
                                        </div>
                                        <!-- Top bar info -->
                                        <div class="relative z-10 flex items-center justify-between">
                                            <span class="text-[10px] font-bold text-dark-bg dark:text-white bg-white/70 dark:bg-black/50 backdrop-blur-sm px-2 py-0.5 rounded-full">Florian G. K.</span>
                                            <div class="flex gap-1">
