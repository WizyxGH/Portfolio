    <script>
        // @ts-nocheck
        document.addEventListener("DOMContentLoaded", () => {
            const cards = document.querySelectorAll(".animate-on-scroll");
            if (cards.length) {
                const observer = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add("show");
                            observer.unobserve(entry.target);
                        }
                    });
                }, { threshold: 0.1 });

                cards.forEach((card) => {
                    observer.observe(card);
                });
            }

            // Process Step Intersection Observer
            const processSteps = document.querySelectorAll(".process-step");
            const firstStep = document.querySelector(".process-step[data-step='1']");

            // Function to set a step as active and others inactive
            function activateStep(activeStepId) {
                processSteps.forEach(step => {
                    const stepId = step.getAttribute("data-step");
                    const stepTitle = step.querySelector(".step-title");
                    const stepDesc = step.querySelector(".step-desc");
                    const stepBadge = step.querySelector(".step-number-badge");
                    const illustration = document.getElementById(`illustration-${stepId}`);
                    const isActive = stepId === activeStepId;

                    if (isActive) {
                        step.classList.add("border-brand-primary", "dark:border-brand-secondary");
                        step.classList.remove("border-gray-100", "dark:border-gray-800");
                        if (stepTitle) {
                            stepTitle.classList.add("text-dark-bg", "dark:text-white");
                            stepTitle.classList.remove("text-gray-400", "dark:text-gray-600");
                        }
                        if (stepDesc) {
                            stepDesc.classList.add("text-gray-600", "dark:text-gray-300");
                            stepDesc.classList.remove("text-gray-400", "dark:text-gray-600");
                        }
                        if (stepBadge) {
                            stepBadge.classList.add("bg-brand-primary", "text-white");
                            stepBadge.classList.remove("bg-gray-200", "dark:bg-gray-800", "text-gray-500", "dark:text-gray-400");
                        }
                        if (illustration) {
                            illustration.classList.add("opacity-100", "scale-100");
                            illustration.classList.remove("opacity-0", "scale-95", "pointer-events-none");
                        }
                    } else {
                        step.classList.remove("border-brand-primary", "dark:border-brand-secondary");
                        step.classList.add("border-gray-100", "dark:border-gray-800");
                        if (stepTitle) {
                            stepTitle.classList.remove("text-dark-bg", "dark:text-white");
                            stepTitle.classList.add("text-gray-400", "dark:text-gray-600");
                        }
                        if (stepDesc) {
                            stepDesc.classList.remove("text-gray-600", "dark:text-gray-300");
                            stepDesc.classList.add("text-gray-400", "dark:text-gray-600");
                        }
                        if (stepBadge) {
                            stepBadge.classList.remove("bg-brand-primary", "text-white");
                            stepBadge.classList.add("bg-gray-200", "dark:bg-gray-800", "text-gray-500", "dark:text-gray-400");
                        }
                        if (illustration) {
                            illustration.classList.remove("opacity-100", "scale-100");
                            illustration.classList.add("opacity-0", "scale-95", "pointer-events-none");
                        }
                    }
                });
            }

            // Initialize first step as active on DOM load
            if (firstStep) {
                activateStep("1");
            }

            if (processSteps.length > 0) {
                const processObserver = new IntersectionObserver((entries) => {
                    // Force mobile-only for observer activation (since desktop uses scroll track)
                    if (window.innerWidth >= 1024) return;

                    const intersectingEntry = entries.find(entry => entry.isIntersecting);
                    if (intersectingEntry) {
                        const stepId = intersectingEntry.target.getAttribute("data-step");
                        activateStep(stepId);
                    }
                }, {
                    rootMargin: "-25% 0px -35% 0px",
                    threshold: 0.1
                });

                processSteps.forEach((step, index) => {
                    processObserver.observe(step);

                    // Add click handler to scroll process track (desktop) or step directly (mobile)
                    step.addEventListener("click", () => {
                        if (window.innerWidth >= 1024) {
                            if (!scrollTrack) return;
                            const rect = scrollTrack.getBoundingClientRect();
                            const scrollTrackOffsetTop = window.scrollY + rect.top;
                            const scrollEnd = rect.height - window.innerHeight;
                            const progress = index / (processSteps.length - 1);
                            const targetScrollY = scrollTrackOffsetTop + progress * scrollEnd;
                            window.scrollTo({
                                top: targetScrollY,
                                behavior: "smooth"
                            });
                        } else {
                            step.scrollIntoView({
                                behavior: "smooth",
                                block: "center"
                            });
                        }
                    });
                });

                // Desktop Scrollytelling Pinning logic
                const scrollTrack = document.getElementById("processScrollTrack");
                const translateWrapper = document.getElementById("stepsTranslateWrapper");
                const stepsContainer = document.getElementById("stepsScrollContainer");

                function updateDesktopSteps() {
                    if (window.innerWidth < 1024) {
                        // Reset wrapper transform on mobile
                        if (translateWrapper) translateWrapper.style.transform = "none";
                        return;
                    }

                    if (!scrollTrack || !translateWrapper || !stepsContainer) return;

                    const rect = scrollTrack.getBoundingClientRect();
                    const trackHeight = rect.height;
                    const windowHeight = window.innerHeight;

                    // Pin scrolling range calculation
                    const scrollStart = 0;
                    const scrollEnd = trackHeight - windowHeight;
                    const currentScroll = -rect.top;

                    let progress = currentScroll / scrollEnd;
                    progress = Math.max(0, Math.min(1, progress));

                    // Divide scroll progress into 5 equal zones
                    const stepCount = processSteps.length;
                    const stepProgress = progress * (stepCount - 1);
                    const activeIndex = Math.round(stepProgress);

                    // Activate corresponding step and mockup
                    const activeStep = processSteps[activeIndex];
                    if (activeStep) {
                        const stepId = activeStep.getAttribute("data-step");
                        activateStep(stepId);
                    }

                    // Calculate total height of all steps
                    let totalStepsHeight = 0;
                    processSteps.forEach(step => {
                        totalStepsHeight += step.offsetHeight;
                    });

                    // Centering active step inside stepsScrollContainer with clamping
                    const containerHeight = stepsContainer.offsetHeight;
                    let targetCenteringY = 0;

                    if (activeIndex > 0) {
                        let previousStepsHeight = 0;
                        for (let i = 0; i < activeIndex; i++) {
                            previousStepsHeight += processSteps[i].offsetHeight;
                        }
                        const activeStepHeight = processSteps[activeIndex].offsetHeight;
                        targetCenteringY = -(previousStepsHeight - (containerHeight / 2) + (activeStepHeight / 2));
                    } else {
                        const activeStepHeight = processSteps[0].offsetHeight;
                        targetCenteringY = -(0 - (containerHeight / 2) + (activeStepHeight / 2));
                    }

                    // Clamp targetY:
                    // - Max scroll is 0 (first step aligned to the top)
                    // - Min scroll is containerHeight - totalStepsHeight (last step aligned to the bottom)
                    const minScroll = containerHeight - totalStepsHeight;
                    const maxScroll = 0;
                    const targetY = Math.min(maxScroll, Math.max(minScroll, targetCenteringY));

                    // Apply translation
                    translateWrapper.style.transform = `translateY(${targetY}px)`;
                }

                // Bind event listeners for desktop scrolling
                window.addEventListener("scroll", updateDesktopSteps);
                window.addEventListener("resize", updateDesktopSteps);
                
                // Trigger once on load
                updateDesktopSteps();
            }

            // Testimonials Carousel Logic
            const carouselTrack = document.getElementById("testimonialsTrack");
            const carouselSlides = document.querySelectorAll(".testimonial-slide");
            const carouselDots = document.getElementById("carouselDots");
            let carouselIndex = 0;
            let carouselTimer = null;

            function getCarouselVisibleCount() {
                if (window.innerWidth >= 1024) return 3; // lg
                if (window.innerWidth >= 768) return 2;  // md
                return 1; // mobile
            }

            function updateCarousel() {
                if (!carouselTrack || carouselSlides.length === 0) return;
                
                const visibleCount = getCarouselVisibleCount();
                const maxIdx = Math.max(0, carouselSlides.length - visibleCount);
                
                if (carouselIndex > maxIdx) {
                    carouselIndex = 0;
                }
                
                const slideWidth = carouselSlides[0].offsetWidth;
                const gap = 24; // gap-6 is 24px
                const translateAmt = carouselIndex * (slideWidth + gap);
                
                carouselTrack.style.transform = `translateX(-${translateAmt}px)`;
                
                // Update dots active style
                const dots = carouselDots.querySelectorAll("button");
                dots.forEach((dot, idx) => {
                    if (idx === carouselIndex) {
                        dot.classList.add("bg-brand-primary", "w-6");
                        dot.classList.remove("bg-gray-300", "dark:bg-gray-700", "w-2.5");
                    } else {
                        dot.classList.remove("bg-brand-primary", "w-6");
                        dot.classList.add("bg-gray-300", "dark:bg-gray-700", "w-2.5");
                    }
                });
            }

            function startCarouselAutoplay() {
                stopCarouselAutoplay();
                carouselTimer = setInterval(() => {
                    const visibleCount = getCarouselVisibleCount();
                    const maxIdx = Math.max(0, carouselSlides.length - visibleCount);
                    
                    if (maxIdx === 0) return;
                    
                    if (carouselIndex >= maxIdx) {
                        carouselIndex = 0;
                    } else {
                        carouselIndex++;
                    }
                    updateCarousel();
                }, 4000);
            }

            function stopCarouselAutoplay() {
                if (carouselTimer) {
                    clearInterval(carouselTimer);
                    carouselTimer = null;
                }
            }

            function setupCarouselDots() {
                if (!carouselDots) return;
                carouselDots.innerHTML = "";
                
                const visibleCount = getCarouselVisibleCount();
                const maxIdx = Math.max(0, carouselSlides.length - visibleCount);
                
                for (let i = 0; i <= maxIdx; i++) {
                    const dotButton = document.createElement("button");
                    dotButton.className = "h-2.5 rounded-full transition-all duration-300 " + 
                                          (i === carouselIndex ? "bg-brand-primary w-6" : "bg-gray-300 dark:bg-gray-700 w-2.5");
                    dotButton.setAttribute("aria-label", `Slide ${i + 1}`);
                    dotButton.addEventListener("click", () => {
                        carouselIndex = i;
                        updateCarousel();
                        startCarouselAutoplay(); // Reset timer on interaction
                    });
                    carouselDots.appendChild(dotButton);
                }
            }

            // Carousel Event Listeners
            window.addEventListener("resize", () => {
                setupCarouselDots();
                updateCarousel();
            });

            const carouselContainer = document.getElementById("testimonialsCarousel");
            if (carouselContainer) {
                carouselContainer.addEventListener("mouseenter", stopCarouselAutoplay);
                carouselContainer.addEventListener("mouseleave", startCarouselAutoplay);
            }

            // Initialize Carousel
            if (carouselSlides.length > 0) {
                setupCarouselDots();
                updateCarousel();
                startCarouselAutoplay();
            }

            const faqItems = document.querySelectorAll("#faqList details");
            faqItems.forEach((item) => {
                item.addEventListener("toggle", () => {
                    if (!item.open) return;
                    faqItems.forEach(other => {
                        if (other !== item) other.open = false;
                    });
                });

                // Permettre de fermer la carte en cliquant n'importe où dessus lorsqu'elle est ouverte
                item.addEventListener("click", (e) => {
                    if (e.target.tagName === 'A' || window.getSelection().toString()) return;
                    if (item.open && !e.target.closest('summary')) {
                        e.preventDefault();
                        item.open = false;
                    }
                });
            });
        });
    </script>

</Layout>