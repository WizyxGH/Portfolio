---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/ui/Button.astro';
---
<Layout title="Services" description="" body_class="">
<script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "BreadcrumbList",
            "itemListElement": [
                {
                    "@type": "ListItem",
                    "position": 1,
                    "name": "Accueil",
                    "item": "https://wizyx.me/"
                },
                {
                    "@type": "ListItem",
                    "position": 2,
                    "name": "Services",
                    "item": "https://wizyx.me/services/"
                }
            ]
        }
    </script>
<script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "Service",
            "name": "Design UI/UX et Copywriting",
            "serviceType": ["UI/UX Design", "Copywriting"],
            "description": "Je transforme vos idées en produits performants",
            "provider": {
                "@type": "Person",
                "name": "Florian Gertner Kilian",
                "url": "https://wizyx.me/"
            },
            "areaServed": [
                {
                    "@type": "City",
                    "name": "Toulon",
                    "address": {
                        "@type": "PostalAddress",
                        "addressLocality": "Toulon",
                        "addressCountry": "FR"
                    }
                },
                {
                    "@type": "City",
                    "name": "Nice",
                    "address": {
                        "@type": "PostalAddress",
                        "addressLocality": "Nice",
                        "addressCountry": "FR"
                    }
                },
                {
                    "@type": "Country",
                    "name": "France"
                }
            ],
            "availableChannel": {
                "@type": "ServiceChannel",
                "serviceLocation": {
                    "@type": "VirtualLocation",
                    "url": "https://wizyx.me/services/"
                }
            }
        }
    </script>
<main class="flex-1 flex flex-col">
        <section class="w-full px-8 lg:px-32 py-8" id="services">
            <div class="max-w-6xl mx-auto text-center space-y-8">
                <div>
                    <h2 class="text-2xl text-dark-bg dark:text-white font-medium mb-4">
                        Mes services
                    </h2>
                    <div class="inline-flex items-center gap-2 rounded-full bg-brand-primary px-4 py-1.5 text-white">
                        <i class='bx bxs-star'></i>
                        <span class="text-sm font-semibold">Rejoignez 100% de clients satisfaits</span>
                    </div>
                </div>
                <!-- Grille -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <!-- Carte 1 -->
                    <div
                        class="relative bg-white dark:bg-dark-bg p-6 rounded-2xl border-2 border-brand-light dark:border-[#281E5A] flex flex-col justify-between gap-6 animate-on-scroll transition-all duration-300 hover:scale-[1.03] hover:shadow-2xl hover:border-brand-primary dark:hover:border-brand-secondary text-dark-bg dark:text-white text-left">
                        <span
                            class="absolute top-4 right-4 inline-flex items-center gap-1 px-3 py-1 rounded-full bg-white text-brand-primary text-xs font-semibold shadow-sm border border-brand-light">
                            Best seller
                        </span>

                        <!-- Icon (Preserved) -->
                        <div class="flex items-center justify-center w-12 h-12 rounded-full bg-brand-primary mb-0">
                            <i class='bx bx-layer text-white text-2xl'></i>
                        </div>

                        <div>
                            <h3 class="text-2xl font-bold mb-2">UI/UX Design</h3>
                            <p class="text-sm text-[rgba(18,18,18,0.8)] dark:text-[rgba(255,255,255,0.8)]">
                                Conception de maquettes de sites internet ou d'applications qui convertissent et à votre
                                image
                            </p>
                        </div>

                        <ul class="text-sm">
                            <li class="flex items-center gap-2">
                                <i class='bx bxs-check-circle text-brand-primary text-xl shrink-0'></i>
                                <span>Maquettes UI & UX</span>
                            </li>
                            <li class="flex items-center gap-2">
                                <i class='bx bxs-check-circle text-brand-primary text-xl shrink-0'></i>
                                <span>Responsive</span>
                            </li>
                            <li class="flex items-center gap-2">
                                <i class='bx bxs-check-circle text-brand-primary text-xl shrink-0'></i>
                                <span>Wireframes & prototypage</span>
                            </li>
                            <li class="flex items-center gap-2">
                                <i class='bx bxs-check-circle text-brand-primary text-xl shrink-0'></i>
                                <span>Design System</span>
                            </li>
                            <li class="flex items-center gap-2">
                                <i class='bx bxs-check-circle text-brand-primary text-xl shrink-0'></i>
                                <span>Optimisation de l’expérience utilisateur</span>
                            </li>
                        </ul>

                        <div class="mt-auto flex flex-col gap-2 w-full">
                            <Button href="https://calendly.com/floriangk/30min" target="_blank" rel="noopener noreferrer" variant="primary" size="md" class="w-full">
                                <span>Prendre un rendez-vous</span>
                            </Button>
                            <Button href="/services/ui-ux/" variant="secondary" size="md" class="w-full">
                                <span>Découvrir l'offre en détail</span>
                            </Button>
                        </div>
                    </div>

                    <!-- Carte 2 -->
                    <div class="bg-brand-surface dark:bg-brand-dark p-6 rounded-2xl border border-brand-light/20 dark:border-[#281E5A]/30 flex flex-col justify-between gap-6 animate-on-scroll transition-all duration-300 hover:scale-[1.02] hover:shadow-xl hover:border-brand-primary/30 dark:hover:border-brand-secondary/30 text-dark-bg dark:text-white text-left"
                        style="transition-delay: 100ms;">

                        <!-- Icon (Preserved) -->
                        <div class="flex items-center justify-center w-12 h-12 rounded-full bg-brand-primary mb-0">
                            <i class='bx bx-pen text-white text-2xl'></i>
                        </div>

                        <div>
                            <h3 class="text-2xl font-bold mb-2">Copywriting</h3>
                            <p class="text-sm text-[rgba(18,18,18,0.8)] dark:text-[rgba(255,255,255,0.8)]">
                                Amélioration du message que vous voulez transmettre au monde
                            </p>
                        </div>

                        <ul class="text-sm">
                            <li class="flex items-center gap-2">
                                <i class='bx bxs-check-circle text-brand-primary text-xl shrink-0'></i>
                                <span>Rédaction persuasive</span>
                            </li>
                            <li class="flex items-center gap-2">
                                <i class='bx bxs-check-circle text-brand-primary text-xl shrink-0'></i>
                                <span>UX Writing</span>
                            </li>
                            <li class="flex items-center gap-2">
                                <i class='bx bxs-check-circle text-brand-primary text-xl shrink-0'></i>
                                <span>Storytelling</span>
                            </li>
                            <li class="flex items-center gap-2">
                                <i class='bx bxs-check-circle text-brand-primary text-xl shrink-0'></i>
                                <span>Optimisation référencement SEO</span>
                            </li>
                        </ul>

                        <Button href="https://calendly.com/floriangk/30min" target="_blank" rel="noopener noreferrer" variant="primary" size="md" class="mt-auto w-full">
                            <span>Prendre un rendez-vous</span>
                        </Button>
                    </div>

                    <!-- Carte 3 -->
                    <div class="bg-brand-surface dark:bg-brand-dark p-6 rounded-2xl border border-brand-light/20 dark:border-[#281E5A]/30 flex flex-col justify-between gap-6 animate-on-scroll transition-all duration-300 hover:scale-[1.02] hover:shadow-xl hover:border-brand-primary/30 dark:hover:border-brand-secondary/30 text-dark-bg dark:text-white text-left"
                        style="transition-delay: 200ms;">

                        <!-- Icon (Preserved) -->
                        <div class="flex items-center justify-center w-12 h-12 rounded-full bg-brand-primary mb-0">
                            <i class='bx bx-bulb text-white text-2xl'></i>
                        </div>

                        <div>
                            <h3 class="text-2xl font-bold mb-2">Une autre idée ?</h3>
                            <p class="text-sm text-[rgba(18,18,18,0.8)] dark:text-[rgba(255,255,255,0.8)]">
                                Si vous pensez que je pourrais être un atout dans votre projet
                            </p>
                        </div>

                        <ul class="text-sm">
                            <li class="flex items-center gap-2">
                                <i class='bx bxs-check-circle text-brand-primary text-xl shrink-0'></i>
                                <span>Projet personnalisé</span>
                            </li>
                            <li class="flex items-center gap-2">
                                <i class='bx bxs-check-circle text-brand-primary text-xl shrink-0'></i>
                                <span>Accompagnement créatif</span>
                            </li>
                            <li class="flex items-center gap-2">
                                <i class='bx bxs-check-circle text-brand-primary text-xl shrink-0'></i>
                                <span>Collaboration sur mesure</span>
                            </li>
                        </ul>

                        <Button href="https://calendly.com/floriangk/30min" target="_blank" rel="noopener noreferrer" variant="primary" size="md" class="mt-auto w-full">
                            <span>Prendre un rendez-vous</span>
                        </Button>
                    </div>
                </div>

                <!-- FAQ -->
                <div class="mt-16 text-left">
                    <h4 class="text-brand-primary dark:text-brand-secondary font-semibold mb-2">Questions fréquemment posées</h4>
                    <div class="space-y-3" id="faqList">
                        <details
                            class="group bg-brand-surface dark:bg-brand-dark rounded-2xl border border-brand-light/20 dark:border-[#281E5A]/30 p-6 transition-all duration-300 hover:scale-[1.01] hover:shadow-xl hover:border-brand-primary/30 dark:hover:border-brand-secondary/30">
                            <summary class="flex items-center justify-between cursor-pointer list-none">
                                <span class="text-dark-bg dark:text-white font-medium">Est-ce que votre projet est adapté à mon profil ?</span>
                                <i
                                    class="bx bx-chevron-down text-2xl text-brand-primary dark:text-brand-secondary transition-transform duration-200 group-open:rotate-180"></i>
                            </summary>
                            <p class="mt-3 text-sm text-dark-bg dark:text-white leading-relaxed">
                                J’accompagne tous types de projets qui ont besoin de clarté, d’esthétique et
                                d’efficacité :
                                site internet, application mobile, landing page, SaaS, dashboard, etc.
                                <br>Que vous ayez une vision très précise ou seulement une idée de départ, que vous
                                soyez
                                expert en tech ou totalement novice, je m’adapte à vos connaissances et à vos attentes.
                                <br>Mon rôle est de transformer vos besoins et vos idées en une interface moderne,
                                cohérente
                                et intuitive — sans jargon, et en vous guidant à chaque étape du processus.
                            </p>
                        </details>
                        <details
                            class="group bg-brand-surface dark:bg-brand-dark rounded-2xl border border-brand-light/20 dark:border-[#281E5A]/30 p-6 transition-all duration-300 hover:scale-[1.01] hover:shadow-xl hover:border-brand-primary/30 dark:hover:border-brand-secondary/30">
                            <summary class="flex items-center justify-between cursor-pointer list-none">
                                <span class="text-dark-bg dark:text-white font-medium">Puis-je commencer par un petit
                                    projet (audit, optimisation...) ?</span>
                                <i
                                    class="bx bx-chevron-down text-2xl text-brand-primary dark:text-brand-secondary transition-transform duration-200 group-open:rotate-180"></i>
                            </summary>
                            <p class="mt-3 text-sm text-dark-bg dark:text-white leading-relaxed">
                                Bien sûr. Un audit UX/UI, une optimisation ciblée ou une petite refonte peuvent déjà
                                apporter des résultats rapides : clarifier une direction, résoudre un blocage ou
                                améliorer
                                des écrans clés.<br>C’est également un excellent moyen de démarrer en douceur et de
                                tester
                                notre collaboration avant de passer à un projet plus ambitieux.
                            </p>
                        </details>
                        <details
                            class="group bg-brand-surface dark:bg-brand-dark rounded-2xl border border-brand-light/20 dark:border-[#281E5A]/30 p-6 transition-all duration-300 hover:scale-[1.01] hover:shadow-xl hover:border-brand-primary/30 dark:hover:border-brand-secondary/30">
                            <summary class="flex items-center justify-between cursor-pointer list-none">
                                <span class="text-dark-bg dark:text-white font-medium">Comment va se dérouler notre
                                    collaboration ?</span>
                                <i
                                    class="bx bx-chevron-down text-2xl text-brand-primary dark:text-brand-secondary transition-transform duration-200 group-open:rotate-180"></i>
                            </summary>
                            <p class="mt-3 text-sm text-dark-bg dark:text-white leading-relaxed">
                                Cela dépend de la complexité de votre demande. De façon simple, transparente et
                                structurée :
                            </p>
                            <ol class="mt-3 ml-4 list-decimal text-sm text-dark-bg dark:text-white leading-relaxed">
                                <li>Appel découverte : pour comprendre vos besoins et définir les priorités.</li>
                                <li>Phase UX : parcours utilisateur, arborescence, wireframes et logique fonctionnelle.
                                </li>
                                <li>Phase UI : création d’un design moderne, soigné et cohérent.</li>
                                <li>Prototype : vous testez l’expérience, nous ajustons ensemble.</li>
                                <li>Livraison : fichiers Figma et sources organisés avec des conseils d’intégration pour
                                    votre développeur.</li>
                            </ol>
                            <p class="mt-3 text-sm text-dark-bg dark:text-white leading-relaxed">
                                La communication peut se faire via différents canaux : WhatsApp, LinkedIn, Slack,
                                Telegram
                                ou encore Discord, avec des points rapides quand nécessaire.<br>L'objectif est d'avancer
                                vite, efficacement et sans réunions interminables.
                            </p>
                        </details>
                        <details
                            class="group bg-brand-surface dark:bg-brand-dark rounded-2xl border border-brand-light/20 dark:border-[#281E5A]/30 p-6 transition-all duration-300 hover:scale-[1.01] hover:shadow-xl hover:border-brand-primary/30 dark:hover:border-brand-secondary/30">
                            <summary class="flex items-center justify-between cursor-pointer list-none">
                                <span class="text-dark-bg dark:text-white font-medium">Que vais-je recevoir à la fin
                                    du
                                    projet ?</span>
                                <i
                                    class="bx bx-chevron-down text-2xl text-brand-primary dark:text-brand-secondary transition-transform duration-200 group-open:rotate-180"></i>
                            </summary>
                            <p class="mt-3 text-sm text-dark-bg dark:text-white leading-relaxed">
                                Vous repartez avec :
                                <br>des maquettes Figma propres, organisées et même maintenables facilement
                                <br>un prototype interactif pour visualiser l’expérience,
                                <br>un mini design system (couleurs, typographies, composants),
                                <br>tous les assets exportés et prêts à l’intégration,
                                <br>des recommandations UI/UX pour la suite de votre produit.
                                <br>Chaque élément est pensé pour être simple à intégrer et faciliter le travail de
                                développement.
                            </p>
                        </details>
                        <details
                            class="group bg-brand-surface dark:bg-brand-dark rounded-2xl border border-brand-light/20 dark:border-[#281E5A]/30 p-6 transition-all duration-300 hover:scale-[1.01] hover:shadow-xl hover:border-brand-primary/30 dark:hover:border-brand-secondary/30">
                            <summary class="flex items-center justify-between cursor-pointer list-none">
                                <span class="text-dark-bg dark:text-white font-medium">En combien de temps mon projet
                                    peut-il être livré ?</span>
                                <i class="bx bx-chevron-down text-2xl text-brand-primary dark:text-brand-secondary transition-transform duration-200 group-open:rotate-180"></i>
                            </summary>
                            <p class="mt-3 text-sm text-dark-bg dark:text-white leading-relaxed">
                                La durée de conception d'un projet dépend de sa complexité et du nombre d'écrans à concevoir. Je vous donnerai une estimation précise lors de notre premier échange afin de s'assurer que cela convient avec vos deadlines.
                            </p>
                        </details>
                        <details
                            class="group bg-brand-surface dark:bg-brand-dark rounded-2xl border border-brand-light/20 dark:border-[#281E5A]/30 p-6 transition-all duration-300 hover:scale-[1.01] hover:shadow-xl hover:border-brand-primary/30 dark:hover:border-brand-secondary/30">
                            <summary class="flex items-center justify-between cursor-pointer list-none">
                                <span class="text-dark-bg dark:text-white font-medium">Comment fonctionne la
                                    rémunération
                                    ?</span>
                                <i
                                    class="bx bx-chevron-down text-2xl text-brand-primary dark:text-brand-secondary transition-transform duration-200 group-open:rotate-180"></i>
                            </summary>
                            <p class="mt-3 text-sm text-dark-bg dark:text-white leading-relaxed">
                                Une fois que l'on s'est mis d'accord sur le prix et les modalités, je vous enverrai un devis suivi d'un contrat. Vous disposerez jusqu'à la fin du mois suivant pour effectuer le paiement.
                            </p>
                        </details>
                    </div>
                </div>
            </div>
        </section>
    </main>

    


    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const cards = document.querySelectorAll("#services .animate-on-scroll");
            if (cards.length) {
                const observer = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add("show");
                            observer.unobserve(entry.target);
                        }
                    });
                }, { threshold: 0.1 });

                cards.forEach((card, i) => {
                    (card as HTMLElement).style.transitionDelay = `${i * 150}ms`;
                    observer.observe(card);
                });
            }

            const faqItems = document.querySelectorAll("#faqList details");
            faqItems.forEach((item) => {
                const detailsItem = item as HTMLDetailsElement;
                detailsItem.addEventListener("toggle", () => {
                    if (!detailsItem.open) return;
                    faqItems.forEach(other => {
                        if (other !== detailsItem) (other as HTMLDetailsElement).open = false;
                    });
                });

                // Permettre de fermer la carte en cliquant n'importe où dessus lorsqu'elle est ouverte
                detailsItem.addEventListener("click", (e) => {
                    const target = e.target as HTMLElement;
                    if (!target) return;
                    if (target.tagName === 'A' || window.getSelection()?.toString()) return;
                    if (detailsItem.open && !target.closest('summary')) {
                        e.preventDefault();
                        detailsItem.open = false;
                    }
                });
            });
        });
    </script>

</Layout>