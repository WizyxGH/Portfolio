---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import Hero from '../components/home/Hero.astro';
import AboutStats from '../components/home/AboutStats.astro';
import Testimonials from '../components/home/Testimonials.astro';
import ProjectCard from '../components/ui/ProjectCard.astro';

const allProjects = await getCollection('projects');
const creations = allProjects.filter((item: any) => item.data.id <= 25);
const roundedCount = Math.floor(creations.length / 10) * 10;

const featured_projects = allProjects
    .sort((a: any, b: any) => a.data.id - b.data.id)
    .filter(project => project.data.is_study !== true)
    .slice(0, 6);
---
<Layout title="Portfolio Florian Gertner Kilian" description="" body_class="">
<script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "Person",
            "name": "Florian Gertner Kilian",
            "alternateName": "Wizyx",
            "givenName": "Florian",
            "familyName": "Gertner Kilian",
            "gender": "Male",
            "jobTitle": "Product Designer UI/UX",
            "url": "https://wizyx.me/",
            "image": "https://wizyx.me/assets/media/photo.webp",
            "description": "Je transforme vos idées en produits performants",
            "address": [
                {
                    "@type": "PostalAddress",
                    "addressLocality": "Toulon"
                },
                {
                    "@type": "PostalAddress",
                    "addressLocality": "Nice"
                }
            ],
            "knowsAbout": [
                "Product Design",
                "UI/UX Design",
                "Copywriting"
            ],
            "knowsLanguage": [
                { "@type": "Language", "name": "Français", "alternateName": "fr" },
                { "@type": "Language", "name": "Anglais", "alternateName": "en" },
                { "@type": "Language", "name": "Allemand", "alternateName": "de" }
            ],
            "nationality": "Française",
            "sameAs": [
                "https://linkedin.com/in/flogk/",
                "https://github.com/WizyxGH",
                "https://t.me/wizyx0"
            ],
            "hasOccupation": {
                "@type": "Occupation",
                "name": "Product Designer",
                "description": "Créations d'interfaces utilisateurs premium, esthétiques et intuitives qui allient design et storytelling."
            },
            "contactPoint": {
                "@type": "ContactPoint",
                "contactType": "Portfolio contact",
                "email": "hello@wizyx.me",
                "url": "https://wizyx.me/contact"
            }
        }
    </script>
<script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "WebSite",
            "name": "Wizyx - Portfolio",
            "url": "https://wizyx.me/",
            "potentialAction": {
                "@type": "SearchAction",
                "target": "https://wizyx.me/creations/?q={search_term_string}",
                "query-input": "required name=search_term_string"
            }
        }
    </script>
<script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "BreadcrumbList",
            "itemListElement": [
                {
                    "@type": "ListItem",
                    "position": 1,
                    "name": "Accueil",
                    "item": "https://wizyx.me/"
                }
            ]
        }
    </script>
<script src="/assets/js/home.js" defer></script>
<script src="/assets/js/brands_carousel.js" defer></script>
    <Hero />

    <AboutStats roundedCount={roundedCount} />

    <!-- Projects Section -->
    <section class="p-8 lg:px-32 bg-brand-muted dark:bg-brand-dark space-y-8">
        <div class="">
            <h2 class="text-2xl font-semibold text-dark-bg dark:text-white mb-2">Mes réalisations</h2>
            <p class="text-sm text-[#3E3E3E] dark:text-[#B0B0B0]">
                Maquettes de site internet, landing page, application mobile, SaaS
            </p>
        </div>

        <!-- Projects Carousel (will be populated by existing projects.json) -->
        <div class="overflow-x-auto mb-8 -mx-8 lg:-mx-32 lg:px-32 scrollbar-hide">
            <div class="flex gap-6 pb-4 px-8 lg:px-0 cursor-grab after:content-[''] after:min-w-8 after:block after:h-1"
                id="projects-grid" data-drag-scroll>
                {featured_projects.map((project) => (
                    <div class="flex-shrink-0 w-80">
                        <ProjectCard project={project} />
                    </div>
                ))}
            </div>
        </div>

        <div class="text-right">
            <a href="/creations/"
                class="inline-flex items-center gap-2 text-dark-bg dark:text-white font-semibold text-base hover:text-brand-primary dark:hover:text-brand-primary transition-colors">
                Voir tous les projets
                <i class='bx bx-right-arrow-alt text-xl'></i>
            </a>
        </div>
    </section>

    <Testimonials />

    



    <!-- Load Projects Script was removed in favor of SSR -->
    <script src="/assets/js/drag_scroll.js" defer></script>

</Layout>