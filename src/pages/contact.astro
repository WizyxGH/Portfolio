---
import Layout from '../layouts/Layout.astro';
import Button from '../components/ui/Button.astro';
import ContactForm from '../components/contact/ContactForm.astro';
import CalendlyCard from '../components/ui/CalendlyCard.astro';
import ContactAdvice from '../components/contact/ContactAdvice.astro';
---
<Layout title="Contact" description="" body_class="">
<script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "BreadcrumbList",
            "itemListElement": [
                {
                    "@type": "ListItem",
                    "position": 1,
                    "name": "Accueil",
                    "item": "https://wizyx.me/"
                },
                {
                    "@type": "ListItem",
                    "position": 2,
                    "name": "Contact",
                    "item": "https://wizyx.me/contact/"
                }
            ]
        }
    </script>
<script src="/assets/js/contact.js" defer></script>
<main class="flex-1 flex flex-col">
        <section class="w-full max-w-5xl mx-auto px-6 py-8 text-center space-y-8">
            <div>
                <h2 class="text-3xl lg:text-4xl font-bold text-dark-bg dark:text-white mb-4">
                    Discutons de votre projet
                </h2>
                <div class="inline-flex items-center gap-2 rounded-full bg-brand-primary px-4 py-1.5 text-white">
                    <i class='bx bxs-wink-smile'></i>
                    <span class="text-sm font-semibold">Réponse sous 24h</span>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12 items-start">
                <ContactForm />

                <!-- Carte Calendly -->
                <CalendlyCard />
            </div>
        </section>

        <!-- Section: Bien préparer notre appel -->
        <ContactAdvice />
    </main>

</Layout>